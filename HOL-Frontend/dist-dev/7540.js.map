                <div class="status-card-header mb-2">
                  <div class="flex items-center gap-2">
                    <div class="status-icon-box bg-indigo-50 text-indigo-500">📡</div>
                    <div>
                      <div class="status-label-main text-[11px]">حالة المتابعة</div>
