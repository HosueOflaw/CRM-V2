<app-lookup-modal #lookupModal [title]="'اختيار ' + currentField" [columns]="['Id', 'Code', 'Name']" [data]="lookupData"
  (itemSelected)="onLookupSelected($event)"></app-lookup-modal>

<!-- Main Page Tabs -->
<div class="premium-tabs-container w-full overflow-x-auto">
  <button class="premium-tab" [class.active]="activeMainTab === 'clients'" (click)="setMainTab('clients')">
    العملاء
  </button>
  <button class="premium-tab" [class.active]="activeMainTab === 'main'" (click)="setMainTab('main')">
    الرئيسية
  </button>
  <button class="premium-tab" [class.active]="activeMainTab === 'searchNumbers'" (click)="setMainTab('searchNumbers')">
    بحث أرقام
  </button>
  <button class="premium-tab" [class.active]="activeMainTab === 'menuSearch'" (click)="setMainTab('menuSearch')">
    قائمة البحث
  </button>
  <button class="premium-tab" [class.active]="activeMainTab === 'FeesAndCollection'"
    (click)="setMainTab('FeesAndCollection')">
    الرسوم والتحصيل
  </button>
  <button class="premium-tab" [class.active]="activeMainTab === 'notes'" (click)="setMainTab('notes')">
    ملاحظات
  </button>
  <button class="premium-tab" [class.active]="activeMainTab === 'preview'" (click)="setMainTab('preview')">
    Preview
  </button>
  <button class="premium-tab" [class.active]="activeMainTab === 'newFiles'" (click)="setMainTab('newFiles')">
    الملفات الجديدة
  </button>
  <button class="premium-tab" [class.active]="activeMainTab === 'statements'" (click)="setMainTab('statements')">
    الافادات
  </button>
  <button class="premium-tab" [class.active]="activeMainTab === 'searchStatements'"
    (click)="setMainTab('searchStatements')">
    بحث الافادات
  </button>
  <button class="premium-tab" [class.active]="activeMainTab === 'stats'" (click)="setMainTab('stats')">
    الاحصائيات
  </button>
</div>

<!-- clients -->
<div *ngIf="activeMainTab === 'clients'" class="page-content">
  <div
    class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
    <table class="premium-table w-full">
      <thead>
        <tr
          class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">#</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الكود</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الاسم</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الموكل</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">حالة المتابعة</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">حالة العميل</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">حالة التواصل</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">حالة التعاون</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">حالة المدنية</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">حالة الداخلية</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">اخر سداد</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">تاريخ اخر سداد</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">اخر افادة</th>
          <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">تاريخ اخر افادة</th>
        </tr>
      </thead>
      <tbody class="text-[11px]">
        <tr *ngFor="let row of clientRows; let i = index" (click)="selectFile(row)"
          class="border-b border-slate-50 dark:border-slate-800 hover:bg-blue-50/50 dark:hover:bg-blue-900/10 cursor-pointer transition-colors">
          <td class="py-2 px-3 text-center text-slate-400 font-mono">{{ i + 1 }}</td>
          <td class="py-2 px-3 font-medium text-slate-600 dark:text-slate-400">{{row.code}}</td>
          <td class="py-2 px-3 font-bold text-indigo-600 dark:text-indigo-400">{{row.name}}</td>
          <td class="py-2 px-3 text-slate-400 max-w-[100px] truncate" [title]="row.client">{{row.client}}</td>
          <td class="py-2 px-3 italic">{{row.followUpStatus}}</td>
          <td class="py-2 px-3 italic">{{row.clientStatus}}</td>
          <td class="py-2 px-3 italic">{{row.contactStatus}}</td>
          <td class="py-2 px-3 italic">{{row.cooperationStatus}}</td>
          <td class="py-2 px-3 italic">{{row.civilStatus}}</td>
          <td class="py-2 px-3 italic">{{row.internalStatus}}</td>
          <td class="py-2 px-3 text-emerald-500 font-bold">{{row.lastPaymentAmount | number}}</td>
          <td class="py-2 px-3 text-slate-400">{{row.lastPaymentDate}}</td>
          <td class="py-2 px-3 text-slate-400 truncate max-w-[150px]" [title]="row.lastStatement">{{row.lastStatement}}
          </td>
          <td class="py-2 px-3 text-slate-400">{{row.lastStatementDate}}</td>
        </tr>

        <tr *ngIf="!clientRows || clientRows.length === 0">
          <td colspan="29" class="text-center py-20 bg-slate-50/20 dark:bg-slate-900/10">
            <div class="flex flex-col items-center gap-3">
              <span class="text-4xl grayscale opacity-50">🔍</span>
              <span class="text-slate-400 italic">لا توجد سجلات مطابقة للبحث</span>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<!-- main -->
<div *ngIf="activeMainTab === 'main'" class="page-content">
  <div class="flex flex-col gap-4">
    <!-- Top Section: Client Info & Financial -->
    <div class="grid grid-cols-12 gap-4">
      <!-- Client Details Card -->
      <div class="col-span-3 premium-card">
        <div class="card-body">
          <div class="form-grid">
            <div class="form-field">
              <label class="form-label">الموكل</label>
              <input type="text" class="form-input" [value]="selectedPerson?.clientName || 'غير موجود'" readonly />
            </div>
            <div class="form-field">
              <label class="form-label">العميل</label>
              <input type="text" class="form-input" [value]="selectedPerson?.customerName || 'غير موجود'" readonly />
            </div>
            <div class="form-field">
              <label class="form-label">المدني</label>
              <input type="text" class="form-input" [value]="selectedPerson?.nationalId || 'غير موجود'" readonly />
            </div>
            <div class="form-field">
              <label class="form-label">الحالة</label>
              <input type="text" class="form-input" [value]="selectedPerson?.status || 'غير موجود'" readonly />
            </div>
            <div class="form-field">
              <label class="form-label">الجنسية</label>
              <input type="text" class="form-input" [value]="selectedPerson?.nationality || 'غير موجود'" readonly />
            </div>
            <div class="form-field">
              <label class="form-label">التصنيف</label>
              <input type="text" class="form-input"
                [value]="selectedPerson?.classification?.classification || 'غير موجود'" readonly />
            </div>
            <div class="form-field">
              <label class="form-label">العقد</label>
              <input type="text" class="form-input" [value]="selectedPerson?.contract || 'غير موجود'" readonly />
            </div>
            <div class="form-field">
              <label class="form-label">المديونية</label>
              <input type="text" class="form-input" [value]="selectedPerson?.debt || 'غير موجود'" readonly />
            </div>
            <div class="form-field">
              <label class="form-label">الأرقام الآلية</label>
              <input type="text" class="form-input" [value]="selectedPerson?.autoNumbers || 'غير موجود'" readonly />
            </div>
            <div class="form-field">
              <label class="form-label">الباتش</label>
              <input type="text" class="form-input" [value]="selectedPerson?.batch || 'غير موجود'" readonly />
            </div>
          </div>
          <div class="form-field form-field-full">
            <label class="form-label">العنوان</label>
            <input type="text" class="form-input" [value]="selectedPerson?.address || 'غير موجود'" readonly />
          </div>
        </div>
      </div>
      <!-- Main Content Card -->
      <div class="col-span-9 premium-card">
        <div class="card-body">

          <div class="premium-tabs-container w-full overflow-x-auto">
            <a class="premium-tab" [class.active]="activeSubTab === 'main'" (click)="changeTab('main')">
              الرئيسية
            </a>
            <a class="premium-tab" [class.active]="activeSubTab === 'classification'"
              (click)="changeTab('classification')">
              تصنيف
            </a>
            <a class="premium-tab" [class.active]="activeSubTab === 'totalFiles'" (click)="changeTab('totalFiles')">
              اجمالي الملفات
            </a>
            <a class="premium-tab" [class.active]="activeSubTab === 'companyLink'" (click)="changeTab('companyLink')">
              رابط الشركة
            </a>

            <a class="premium-tab" [class.active]="activeSubTab === 'legal'" (click)="changeTab('legal')">
              الرسوم
            </a>
            <a class="premium-tab" [class.active]="activeSubTab === 'files'" (click)="changeTab('files')">
              تفاصيل المطالبة
            </a>
            <a class="premium-tab" [class.active]="activeSubTab === 'checks'" (click)="changeTab('checks')">
              الشيكات
            </a>
            <a class="premium-tab" [class.active]="activeSubTab === 'attachments'" (click)="changeTab('attachments')">
              المرفقات
            </a>
            <a class="premium-tab" [class.active]="activeSubTab === 'history'" (click)="changeTab('history')">
              التصنيفات
            </a>

            <a class="premium-tab" [class.active]="activeSubTab === 'callcenter'" (click)="changeTab('callcenter')">
              إفادات الكول سنتر
            </a>

            <!-- Excel Export Button -->
            <button class="btn-excel" (click)="exportActiveTabToExcel()" title="تصدير البيانات الحالية إلى ملف إكسل">
              <span>تصدير إكسل</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10 9 9 9 8 9"></polyline>
              </svg>
            </button>
          </div>

          <div *ngIf="activeSubTab === 'main'">
            <!-- Removed style="display: block;" which was breaking the grid -->
            <div class="grid grid-cols-12 gap-6 p-2" dir="rtl">

              <!-- ========================= -->
              <!-- 🟦 اليمين (النص الأول) -->
              <!-- ========================= -->
              <div class="col-span-12 lg:col-span-8 space-y-6">

                <!-- القطاع + المحامي + اسم المدعي -->
                <div class="form-grid form-grid-3">
                  <div class="form-field">
                    <label class="form-label">القطاع</label>
                    <input type="text" class="premium-input" [value]="selectedFile?.mdName || ''" readonly />
                  </div>
                  <div class="form-field">
                    <label class="form-label">المحامي</label>
                    <input type="text" class="premium-input" [value]="selectedFile?.lawyerName || ''" readonly />
                  </div>
                  <div class="form-field">
                    <label class="form-label">اسم المدعي القانوني</label>
                    <input type="text" class="premium-input" [value]="selectedFile?.name || ''" readonly />
                  </div>
                  <div class="form-field">
                    <label class="form-label">المستشار القانوني</label>
                    <input type="text" class="premium-input" [value]="selectedFile?.advisorName || ''" readonly />
                  </div>
                </div>

                <!-- الملاحظات Tabs -->
                <div class="premium-card p-4">
                  <div class="premium-tabs-container w-full overflow-x-auto mb-4"
                    style="margin-bottom: 1rem; padding: 0.25rem;">
                    <button class="premium-tab text-sm" [class.active]="activeNoteTab===1"
                      (click)="activeNoteTab=1">ملاحظات</button>
                    <button class="premium-tab text-sm" [class.active]="activeNoteTab===2"
                      (click)="activeNoteTab=2">ملاحظات 2</button>
                    <button class="premium-tab text-sm" [class.active]="activeNoteTab===3"
                      (click)="activeNoteTab=3">ملاحظات 3</button>
                    <button class="premium-tab text-sm" [class.active]="activeNoteTab===4"
                      (click)="activeNoteTab=4">ملاحظات 4</button>
                    <button class="premium-tab text-sm" [class.active]="activeNoteTab===5"
                      (click)="activeNoteTab=5">السكرتارية</button>
                    <button class="premium-tab text-sm" [class.active]="activeNoteTab===6"
                      (click)="activeNoteTab=6">ملاحظات 6</button>
                  </div>

                  <textarea *ngIf="activeNoteTab===1" class="premium-input" rows="4" [value]="selectedFile?.note1 || ''"
                    readonly></textarea>
                  <textarea *ngIf="activeNoteTab===2" class="premium-input" rows="4" [value]="selectedFile?.note2 || ''"
                    readonly></textarea>
                  <textarea *ngIf="activeNoteTab===3" class="premium-input" rows="4" [value]="selectedFile?.note3 || ''"
                    readonly></textarea>
                  <textarea *ngIf="activeNoteTab===4" class="premium-input" rows="4" [value]="selectedFile?.note4 || ''"
                    readonly></textarea>
                  <textarea *ngIf="activeNoteTab===5" class="premium-input" rows="4" [value]="selectedFile?.note5 || ''"
                    readonly></textarea>
                  <textarea *ngIf="activeNoteTab===6" class="premium-input" rows="4" [value]="selectedFile?.note6 || ''"
                    readonly></textarea>
                </div>

                <div class="flex flex-col xl:flex-row justify-between gap-6">
                  <!-- التواريخ -->
                  <div class="premium-card" style="flex: 2; margin-bottom: 0 !important;">
                    <div class="card-body p-0">
                      <div class="grid grid-cols-2 gap-4">
                        <div class="form-field">
                          <label class="form-label">تاريخ الورود</label>
                          <input type="date" class="premium-input" [value]="selectedFile?.dateAdded | date:'yyyy-MM-dd'"
                            readonly />
                        </div>
                        <div class="form-field">
                          <label class="form-label">تاريخ الاستلام</label>
                          <input type="date" class="premium-input" [value]="selectedFile?.dateAdded | date:'yyyy-MM-dd'"
                            readonly />
                        </div>
                        <div class="form-field">
                          <label class="form-label">تاريخ السحب</label>
                          <input type="date" class="premium-input"
                            [value]="selectedFile?.dateFinished | date:'yyyy-MM-dd'" readonly />
                        </div>
                        <div class="form-field">
                          <label class="form-label">تاريخ أول ورود</label>
                          <input type="date" class="premium-input" [value]="selectedFile?.dateAdded | date:'yyyy-MM-dd'"
                            readonly />
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- النوع + اللغة -->
                  <div class="flex flex-col gap-4" style="flex: 1;">
                    <div class="premium-card p-4" style="margin-bottom: 0 !important;">
                      <div class="card-body p-0">
                        <label class="form-label mb-3">لغة التواصل</label>
                        <div class="premium-radio-group">
                          <label *ngFor="let item of lookupLists.comms_lang" class="premium-radio-item"
                            [class.active]="selectedPerson?.classification?.communicationLanguageId === item.id"
                            (click)="onLookupSelected(item, 'comms_lang')">
                            <input type="radio" name="comms_lang" [value]="item.id"
                              [checked]="selectedPerson?.classification?.communicationLanguageId === item.id">
                            <span>{{item.name}}</span>
                          </label>
                        </div>
                      </div>
                    </div>

                    <div class="premium-card p-4" style="margin-bottom: 0 !important;">
                      <div class="card-body p-0">
                        <label class="form-label mb-3">النوع</label>
                        <div class="premium-radio-group">
                          <label *ngFor="let item of lookupLists.gender" class="premium-radio-item"
                            [class.active]="selectedPerson?.classification?.genderId === item.id"
                            (click)="onLookupSelected(item, 'gender')">
                            <input type="radio" name="gender" [value]="item.id"
                              [checked]="selectedPerson?.classification?.genderId === item.id">
                            <span>{{item.name}}</span>
                          </label>
                        </div>
                      </div>
                    </div>
                  </div>

                </div>

              </div>

              <!-- ========================= -->
              <!-- 🟥 الشمال (النص الثاني) -->
              <!-- ========================= -->
              <div class="col-span-12 lg:col-span-4 space-y-6">

                <!-- المحكمة + الداخلية + المدنية -->
                <div class="premium-card p-4">
                  <div class="form-grid grid-cols-1">
                    <div class="form-field">
                      <label class="form-label">المحكمة</label>
                      <div class="flex gap-2">
                        <input type="text" class="premium-input" style="flex: 1;"
                          [value]="selectedFile?.courtName || 'غير موجود'" readonly />
                        <button class="premium-btn premium-btn-outline px-4" (click)="openLookup('court')">🔍</button>
                      </div>
                    </div>

                  </div>
                </div>

                <!-- أزرار الإجراءات -->
                <div class="premium-card p-4">
                  <h3 class="form-label mb-4">إجراءات سريعة</h3>
                  <div class="flex flex-col gap-3">
                    <button
                      class="premium-btn bg-emerald-500 hover:bg-emerald-600 text-white border-none shadow-sm w-full">حفظ</button>
                    <button class="premium-btn premium-btn-secondary w-full">كشف حساب سيارات</button>
                    <button class="premium-btn premium-btn-secondary w-full">براءة ذمة</button>
                    <button class="premium-btn premium-btn-secondary w-full">استمارة العميل</button>
                    <button class="premium-btn premium-btn-secondary w-full">تصنيف العميل</button>
                  </div>
                </div>

              </div>

            </div>


          </div>

          <!-- (NEW) اجمالي الملفات -->
          <div *ngIf="activeSubTab === 'totalFiles'" class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-4" dir="rtl">

              <!-- Column 1: All Files -->
              <div class="space-y-4">
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-indigo-600 bg-slate-50/50"
                    [value]="totals.claimAll | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">المطالبة لكل الملفات</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-emerald-600 bg-slate-50/50"
                    [value]="totals.paidAll | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">المسدد لكل الملفات</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-rose-600 bg-slate-50/50"
                    [value]="totals.remainingAll | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">المتبقي لكل الملفات</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-slate-600 bg-slate-50/50"
                    [value]="totals.feesAll | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">الرسوم لكل الملفات</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-indigo-800 bg-slate-50/50"
                    [value]="(totals.remainingAll + totals.feesAll) | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">المتبقي شامل الرسوم</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-slate-500 bg-slate-50/50"
                    [value]="totals.proceduresAll" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">الاجراءات لكل الملفات</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-rose-800 bg-slate-50/50"
                    [value]="totals.remainingAll | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">المتبقي لكل الملفات</label>
                </div>
              </div>

              <!-- Column 2: Current Company -->
              <div class="space-y-4">
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-indigo-600 bg-slate-50/50"
                    [value]="(selectedFile?.claim || 0) | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">المطالبة للشركة الحالية</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-emerald-600 bg-slate-50/50"
                    [value]="(selectedFile?.paid || 0) | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">المسدد للشركة الحالية</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-rose-600 bg-slate-50/50"
                    [value]="(selectedFile?.remaining || 0) | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">المتبقي للشركة الحالية</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-slate-600 bg-slate-50/50"
                    [value]="(selectedFile?.fees || 0) | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">الرسوم للشركة الحالية</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-indigo-800 bg-slate-50/50"
                    [value]="((selectedFile?.remaining || 0) + (selectedFile?.fees || 0)) | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">المتبقي شامل الرسوم</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-slate-500 bg-slate-50/50"
                    [value]="0" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">الاجراءات للشركة الحالية</label>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <input type="text" class="premium-input text-center font-bold text-rose-800 bg-slate-50/50"
                    [value]="(selectedFile?.remaining || 0) | number:'1.3-3'" readonly />
                  <label class="text-sm font-bold text-slate-700 w-40 text-right">المتبقي للشركة الحالية</label>
                </div>
              </div>

            </div>
          </div>

          <!-- (NEW) رابط الشركة -->
          <div *ngIf="activeSubTab === 'companyLink'" class="p-6 space-y-6" dir="rtl">
            <!-- Header Section -->
            <div class="flex items-center justify-between border-b border-slate-100 pb-4">
              <div class="flex items-center gap-3">
                <div class="p-2 bg-indigo-50 rounded-xl">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600" fill="none"
                    viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.826c.001-.001 0-1.101 0-1.101m0 0l4-4a4 4 0 015.656 5.656l-1.1 1.1" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-bold text-slate-800">توليد رابط الدفع</h3>
                  <p class="text-xs text-slate-500">قم بإعداد وتجهيز رابط الدفع لإرساله للعميل</p>
                </div>
              </div>
              <div class="flex gap-2">
                <button class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-bold transition-all"
                  [class.bg-indigo-600]="paymentForm.type === 'company'"
                  [class.text-white]="paymentForm.type === 'company'"
                  [class.bg-slate-100]="paymentForm.type !== 'company'"
                  [class.text-slate-600]="paymentForm.type !== 'company'"
                  (click)="paymentForm.type = 'company'; generateLink()">
                  رابط الشركة
                </button>
                <button class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-bold transition-all"
                  [class.bg-indigo-600]="paymentForm.type === 'office'"
                  [class.text-white]="paymentForm.type === 'office'"
                  [class.bg-slate-100]="paymentForm.type !== 'office'"
                  [class.text-slate-600]="paymentForm.type !== 'office'"
                  (click)="paymentForm.type = 'office'; generateLink()">
                  رابط المكتب
                </button>
              </div>
            </div>

            <!-- Main Form Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <!-- Left: Client & Amount Info -->
              <div class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">كود الملف</label>
                    <input type="text" class="premium-input bg-slate-50 font-bold" [value]="paymentForm.code"
                      readonly />
                  </div>
                  <div class="space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">الرقم المدني</label>
                    <input type="text" class="premium-input bg-slate-50 font-mono" [value]="paymentForm.civilId"
                      readonly />
                  </div>
                </div>

                <div class="space-y-1">
                  <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">الاسم</label>
                  <input type="text" class="premium-input bg-slate-50 font-bold" [value]="paymentForm.name" readonly />
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-1">
                    <label class="text-[10px] font-black text-indigo-500 uppercase tracking-widest">المبلغ (د.ك)</label>
                    <input type="number"
                      class="premium-input bg-indigo-50/50 border-indigo-200 text-indigo-700 font-black text-lg"
                      [(ngModel)]="paymentForm.amount" (ngModelChange)="generateLink()" />
                  </div>
                  <div class="space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">المستفيد</label>
                    <input type="text" class="premium-input bg-slate-50" [value]="paymentForm.claimant" readonly />
                  </div>
                </div>
              </div>

              <!-- Right: Config & Output -->
              <div class="space-y-4">
                <div class="space-y-1">
                  <label class="text-[10px] font-black text-emerald-500 uppercase tracking-widest">رقم الواتساب</label>
                  <div class="relative">
                    <input type="text"
                      class="premium-input pl-10 bg-emerald-50/30 border-emerald-100 text-emerald-700 font-bold"
                      [(ngModel)]="paymentForm.whatsapp" />
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 absolute left-3 top-2.5 text-emerald-400"
                      fill="currentColor" viewBox="0 0 24 24">
                      <path
                        d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.44-9.89 9.886-.001 2.15.614 3.735 1.648 5.41l-.999 3.647 3.841-.986zm11.387-5.477c-.31-.156-1.834-.905-2.112-1.006-.277-.101-.48-.151-.68.151-.202.303-.778 1.006-.955 1.208-.177.202-.355.226-.665.071-1.297-.648-2.13-1.153-2.969-2.585-.23-.393-.23-.393.103-.79.314-.374.68-.813.882-1.006l.325-.494c.156-.303.078-.567-.039-.79-.117-.224-.68-1.641-.933-2.25-.246-.591-.497-.504-.68-.514l-.578-.01c-.202 0-.528.077-.803.376-.276.301-1.054 1.03-1.054 2.513 0 1.485 1.079 2.918 1.229 3.12.151.201 2.126 3.245 5.15 4.549 3.023 1.305 3.023.87 3.578.82.555-.05 1.833-.749 2.091-1.478.257-.73.257-1.359.18-1.484-.076-.126-.28-.203-.591-.359z" />
                    </svg>
                  </div>
                </div>

                <div class="space-y-2">
                  <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">اللغة</label>
                  <div class="flex gap-2">
                    <button class="flex-1 py-2 rounded-lg text-sm font-bold border transition-all"
                      [class.bg-slate-800]="paymentForm.language === 'arabic'"
                      [class.border-slate-800]="paymentForm.language === 'arabic'"
                      [class.text-white]="paymentForm.language === 'arabic'"
                      [class.bg-white]="paymentForm.language !== 'arabic'"
                      (click)="paymentForm.language = 'arabic'; generateLink()">
                      العربية
                    </button>
                    <button class="flex-1 py-2 rounded-lg text-sm font-bold border transition-all"
                      [class.bg-slate-800]="paymentForm.language === 'english'"
                      [class.border-slate-800]="paymentForm.language === 'english'"
                      [class.text-white]="paymentForm.language === 'english'"
                      [class.bg-white]="paymentForm.language !== 'english'"
                      (click)="paymentForm.language = 'english'; generateLink()">
                      English
                    </button>
                  </div>
                </div>

                <div class="space-y-1 pt-2">
                  <label class="text-[10px] font-black text-indigo-500 uppercase tracking-widest">الرابط المولد</label>
                  <div class="flex gap-2">
                    <input type="text" class="premium-input bg-slate-50 text-xs font-mono text-indigo-600 flex-1"
                      [value]="companyLink" readonly />
                    <button class="p-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg transition-colors"
                      (click)="copyLink()" title="نسخ الرابط">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M8 5H6a2 2 0 00-2 2v12a2 2 0 00 2 2h10a2 2 0 00 2-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Message Area -->
            <div class="space-y-2">
              <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">نص الرسالة</label>
              <textarea class="premium-input w-full min-h-[120px] bg-slate-50 text-sm leading-relaxed"
                [(ngModel)]="paymentForm.message"></textarea>
            </div>

            <!-- Action Buttons -->
            <div class="flex justify-end gap-3 pt-4">
              <button
                class="premium-btn bg-emerald-600 hover:bg-emerald-700 text-white border-none py-3 px-10 shadow-lg shadow-emerald-200"
                (click)="sendWhatsApp()">
                <div class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path
                      d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.44-9.89 9.886-.001 2.15.614 3.735 1.648 5.41l-.999 3.647 3.841-.986zm11.387-5.477c-.31-.156-1.834-.905-2.112-1.006-.277-.101-.48-.151-.68.151-.202.303-.778 1.006-.955 1.208-.177.202-.355.226-.665.071-1.297-.648-2.13-1.153-2.969-2.585-.23-.393-.23-.393.103-.79.314-.374.68-.813.882-1.006l.325-.494c.156-.303.078-.567-.039-.79-.117-.224-.68-1.641-.933-2.25-.246-.591-.497-.504-.68-.514l-.578-.01c-.202 0-.528.077-.803.376-.276.301-1.054 1.03-1.054 2.513 0 1.485 1.079 2.918 1.229 3.12.151.201 2.126 3.245 5.15 4.549 3.023 1.305 3.023.87 3.578.82.555-.05 1.833-.749 2.091-1.478.257-.73.257-1.359.18-1.484-.076-.126-.28-.203-.591-.359z" />
                  </svg>
                  <span>إرسال عبر واتساب</span>
                </div>
              </button>
            </div>
          </div>


          <div *ngIf="activeSubTab === 'files'" class="p-2">
            <div
              class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
              <table class="premium-table w-full">
                <thead>
                  <tr
                    class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
                    <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الكود</th>
                    <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الموكل</th>
                    <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">سبب المديونية
                    </th>
                    <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المطالبة</th>
                    <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المسدد</th>
                    <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المتبقي</th>
                    <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المحامي</th>
                    <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المحكمة</th>
                  </tr>
                </thead>
                <tbody class="text-[11px]">
                  <tr *ngFor="let row of clientRows"
                    (click)="selectFile(row); selectDebtForModal(row); debtModal.showModal()"
                    class="border-b border-slate-50 dark:border-slate-800 hover:bg-slate-50/80 dark:hover:bg-slate-700/30 cursor-pointer transition-colors">
                    <td class="py-2 px-3 font-medium text-slate-600 dark:text-slate-400">{{row.code}}</td>
                    <td class="py-2 px-3 text-slate-500">{{row.client}}</td>
                    <td class="py-2 px-3 text-slate-500">{{row.debtReason}}</td>
                    <td class="py-2 px-3 font-bold text-rose-600">{{row.claim | number}}</td>
                    <td class="py-2 px-3 font-bold text-emerald-600">{{row.paid | number}}</td>
                    <td class="py-2 px-3 font-bold text-indigo-600">{{row.remaining | number}}</td>
                    <td class="py-2 px-3 text-slate-500">{{row.lawyerName}}</td>
                    <td class="py-2 px-3 text-slate-500">{{row.courtName}}</td>
                  </tr>
                  <tr *ngIf="!clientRows || clientRows.length === 0">
                    <td colspan="8" class="text-center py-12 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">
                      لا توجد ديون مسجلة لهذه الفئة
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- (3) الدفعات والمبالغ -->
          <div *ngIf="activeSubTab === 'payments'" class="p-2 space-y-6">
            <div>
              <div class="flex items-center gap-2 mb-3">
                <span class="w-1.5 h-4 bg-emerald-500 rounded-full"></span>
                <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">سجل الدفعات</h4>
              </div>
              <div
                class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
                <table class="premium-table w-full">
                  <thead>
                    <tr
                      class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">التاريخ</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المبلغ</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الوسيلة</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">بواسطة</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">مندوب
                        المبيعات</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">رقم السند
                      </th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">حالة الملف
                        بعد السداد</th>
                    </tr>
                  </thead>
                  <tbody class="text-[11px]">
                    <tr *ngFor="let p of payments" (click)="selectPaymentForModal(p); paymentModal.showModal()"
                      class="border-b border-slate-50 dark:border-slate-800 hover:bg-emerald-50/30 dark:hover:bg-emerald-900/10 cursor-pointer transition-colors">
                      <td class="py-2 px-3 text-slate-400">{{p.dateAdded | date:'yyyy-MM-dd'}}</td>
                      <td class="py-2 px-3 font-bold text-emerald-600">{{p.value | number}}</td>
                      <td class="py-2 px-3 text-slate-500">{{p.paymentMethod}}</td>
                      <td class="py-2 px-3 font-medium text-slate-600">{{p.userAddedName}}</td>
                      <td class="py-2 px-3 text-slate-400">{{p.salesAgent || '-'}}</td>
                      <td class="py-2 px-3 text-slate-400 font-mono">{{p.jouralEntry || '-'}}</td>
                      <td class="py-2 px-3">
                        <span
                          class="px-2 py-0.5 rounded-lg bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-300 text-[10px] font-bold">
                          {{p.fileStatusAfter || '-'}}
                        </span>
                      </td>
                    </tr>
                    <tr *ngIf="!payments || payments.length === 0">
                      <td colspan="7"
                        class="text-center py-10 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">
                        لا توجد دفعات مسجلة لهذا الملف
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <div>
              <div class="flex items-center gap-2 mb-3">
                <span class="w-1.5 h-4 bg-amber-500 rounded-full"></span>
                <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">المبالغ الإضافية</h4>
              </div>
              <div
                class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
                <table class="premium-table w-full">
                  <thead>
                    <tr
                      class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">التاريخ</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المبلغ</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">النوع</th>
                    </tr>
                  </thead>
                  <tbody class="text-[11px]">
                    <tr *ngFor="let a of additionalAmounts"
                      class="border-b border-slate-50 dark:border-slate-800 hover:bg-amber-50/30 dark:hover:bg-amber-900/10 transition-colors">
                      <td class="py-2 px-3 text-slate-400">{{a.dateAdded | date:'yyyy-MM-dd'}}</td>
                      <td class="py-2 px-3 font-bold text-amber-600">{{a.value | number}}</td>
                      <td class="py-2 px-3 text-slate-500 font-medium">{{a.amountType}}</td>
                    </tr>
                    <tr *ngIf="!additionalAmounts || additionalAmounts.length === 0">
                      <td colspan="3"
                        class="text-center py-10 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">
                        لا توجد مبالغ إضافية مسجلة
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- (4) البيانات القانونية -->
          <div *ngIf="activeSubTab === 'legal'" class="p-2 space-y-6">
            <div>
              <div class="flex items-center gap-2 mb-3">
                <span class="w-1.5 h-4 bg-indigo-500 rounded-full"></span>
                <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">الأرقام الآلية والمراجع</h4>
              </div>
              <div
                class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
                <table class="premium-table w-full">
                  <thead>
                    <tr
                      class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الرقم</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">النوع</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المرجع</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الخصم</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">ملاحظات</th>
                    </tr>
                  </thead>
                  <tbody class="text-[11px]">
                    <tr *ngFor="let n of autoNumbers"
                      class="border-b border-slate-50 dark:border-slate-800 hover:bg-slate-50/50 transition-colors">
                      <td class="py-2 px-3 font-bold text-indigo-600">{{n.autoNumberValue}}</td>
                      <td class="py-2 px-3 text-slate-500">{{n.type}}</td>
                      <td class="py-2 px-3 text-slate-400 font-mono text-[10px]">{{n.caseRef}}</td>
                      <td class="py-2 px-3 text-slate-500">{{n.claimant}}</td>
                      <td class="py-2 px-3 text-slate-400 italic">{{n.note}}</td>
                    </tr>
                    <tr *ngIf="!autoNumbers || autoNumbers.length === 0">
                      <td colspan="5"
                        class="text-center py-10 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">
                        لا توجد أرقام آلية مسجلة
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <div>
              <div class="flex items-center gap-2 mb-3">
                <span class="w-1.5 h-4 bg-slate-400 rounded-full"></span>
                <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">تصنيفات الملف</h4>
              </div>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div *ngFor="let c of classifications"
                  class="p-4 rounded-2xl bg-slate-50/50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-700 transition-all hover:border-indigo-200">
                  <div class="text-[9px] uppercase text-slate-400 dark:text-slate-500 font-bold mb-1">{{c.department}}
                  </div>
                  <div class="text-sm font-bold text-slate-700 dark:text-slate-300">{{c.classification}}</div>
                </div>
              </div>
            </div>
          </div>

          <!-- (NEW) الشيكات -->
          <div *ngIf="activeSubTab === 'checks'" class="p-8 text-center text-slate-400 italic">
            لا توجد شيكات مسجلة حالياً
          </div>


          <!-- (5) المرفقات (Already modernized) -->
          <div *ngIf="activeSubTab === 'attachments'" class="p-2">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div *ngFor="let file of attachments"
                class="flex items-center justify-between p-3 rounded-xl bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 shadow-sm hover:shadow-md transition-all">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary">📄</div>
                  <div>
                    <div class="text-sm font-bold text-slate-700 dark:text-slate-300">{{ file.attachType || 'مرفق' }}
                    </div>
                    <div class="text-[10px] text-slate-400 dark:text-slate-500">{{ file.dateAdded | date: 'yyyy-MM-dd'
                      }}</div>
                  </div>
                </div>
                <button class="premium-btn premium-btn-outline text-xs" (click)="openAttachment(file)">فتح</button>
              </div>
              <div *ngIf="!attachments || attachments.length === 0"
                class="col-span-2 text-center p-12 bg-slate-50/20 dark:bg-slate-900/10 rounded-2xl text-slate-400 italic">
                لا توجد مرفقات لهذا الملف
              </div>
            </div>
          </div>

          <!-- (6) تاريخ الملف -->
          <div *ngIf="activeSubTab === 'history'" class="p-2 space-y-6">
            <div>
              <div class="flex items-center gap-2 mb-3">
                <span class="w-1.5 h-4 bg-indigo-500 rounded-full"></span>
                <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">سجل التعديلات (Audit)</h4>
              </div>
              <div
                class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
                <table class="premium-table w-full">
                  <thead>
                    <tr
                      class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">التاريخ</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الإجراء</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الوصف</th>
                      <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المستخدم
                      </th>
                    </tr>
                  </thead>
                  <tbody class="text-[11px]">
                    <tr *ngFor="let a of audits"
                      class="border-b border-slate-50 dark:border-slate-800 hover:bg-slate-50/50 transition-colors">
                      <td class="py-2 px-3 text-slate-400 text-[10px] font-mono">{{a.actionDate | date:'yyyy-MM-dd
                        HH:mm'}}</td>
                      <td class="py-2 px-3">
                        <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase tracking-tighter" [ngClass]="{
                          'bg-emerald-100 text-emerald-700': a.action === 'ADD' || a.action === 'INSERT',
                          'bg-blue-100 text-blue-700': a.action === 'UPDATE',
                          'bg-rose-100 text-rose-700': a.action === 'DELETE',
                          'bg-slate-100 text-slate-600': !['ADD', 'INSERT', 'UPDATE', 'DELETE'].includes(a.action)
                        }">{{a.action}}</span>
                      </td>
                      <td class="py-2 px-3 text-slate-600 dark:text-slate-400 text-xs">{{a.description}}</td>
                      <td class="py-2 px-3">
                        <div class="flex items-center gap-2">
                          <span
                            class="w-5 h-5 rounded-full bg-indigo-50 flex items-center justify-center text-[9px] font-bold text-indigo-600 border border-indigo-100">{{a.userName?.charAt(0)
                            || 'U'}}</span>
                          <span class="font-medium text-slate-500">{{a.userName}}</span>
                        </div>
                      </td>
                    </tr>
                    <tr *ngIf="!audits || audits.length === 0">
                      <td colspan="4"
                        class="text-center py-12 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">
                        لا توجد سجلات تدقيق متاحة
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- (7) إفادات الكول سنتر -->
          <div *ngIf="activeSubTab === 'callcenter'" class="p-2">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              <div *ngFor="let s of callcenterStatements"
                class="p-4 rounded-2xl bg-gradient-to-br from-white to-slate-50 dark:from-slate-800 dark:to-slate-800 border border-slate-100 dark:border-slate-700 shadow-sm hover:border-primary transition-all group">
                <div class="flex justify-between items-start mb-3">
                  <div class="text-[10px] text-slate-400 dark:text-slate-500 font-bold uppercase tracking-wider">
                    {{s.dateAdded |
                    date:'dd/MM/yyyy HH:mm'}}</div>
                  <span class="px-2 py-0.5 rounded text-[10px] font-bold" [ngClass]="{
                    'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400': s.connectedStatus === 'تم الاتصال',
                    'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400': s.connectedStatus === 'لا يرد',
                    'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400': s.connectedStatus === 'رقم خطأ'
                  }">{{s.connectedStatus}}</span>
                </div>

                <div class="text-lg font-bold text-primary dark:text-primary-focus mb-1">{{s.promiseAmount |
                  number:'1.3-3'}} د.ك</div>
                <div class="text-xs text-slate-600 dark:text-slate-400 mb-3 flex items-center gap-1">
                  <span class="opacity-50">بواسطة:</span> {{s.userAddedName}}
                </div>

                <div class="space-y-2 text-sm border-t border-slate-50 dark:border-slate-700 pt-3">
                  <div class="flex justify-between">
                    <span class="text-slate-400 dark:text-slate-500">الوسيلة:</span>
                    <span class="font-medium text-slate-700 dark:text-slate-300">{{s.contactMethod}}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-slate-400 dark:text-slate-500">رقم الهاتف:</span>
                    <span class="font-medium text-slate-700 dark:text-slate-300">{{s.phoneNumber}}</span>
                  </div>
                </div>

                <div
                  class="mt-4 p-2 bg-slate-50 dark:bg-slate-700/50 rounded-xl text-xs text-slate-500 dark:text-slate-400 italic">
                  {{s.notes || 'لا يوجد ملاحظات'}}
                </div>
              </div>

              <div *ngIf="callcenterStatements.length === 0"
                class="col-span-full text-center p-12 bg-slate-50 dark:bg-slate-800 rounded-3xl border-2 border-dashed border-slate-200 dark:border-slate-700 text-slate-400 dark:text-slate-500">
                <div class="text-4xl mb-2">📋</div>
                لا توجد إفادات مسجلة لهذا الملف
              </div>
            </div>
          </div>

          <!-- (8) تصنيف (Classification Tab Modernized) -->
          <div *ngIf="activeSubTab === 'classification'" class="p-4 animate-in fade-in duration-500 min-h-[400px]">
