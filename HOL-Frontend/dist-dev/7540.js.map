        </h3>

        <div class="flex flex-col gap-3">
          <button class="premium-btn premium-btn-primary w-full" routerLink="/report/add-number">
            <span class="text-lg">➕</span> اضافة كشف
          </button>
          <button class="premium-btn premium-btn-secondary w-full" routerLink="/report/numbers">
            <span class="text-lg">🔍</span> بحث أرقام
          </button>

          <div class="mt-4 pt-4 border-t border-dashed border-slate-200">
            <label class="form-label text-[11px] uppercase tracking-wider">بحث سريع</label>
            <div class="relative">
              <input type="text" class="premium-input pr-10" placeholder="ادخل رقم الكشف..." />
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">🔍</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content Area -->
    <div class="col-span-12 lg:col-span-9">
      <div class="premium-tabs-container mb-4">
        <a class="premium-tab" [class.active]="activeTab === 'numbers'" (click)="activeTab = 'numbers'">
          الرقم
        </a>
        <a class="premium-tab" [class.active]="activeTab === 'add'" (click)="activeTab = 'add'">
          إضافة رقم جديد
        </a>
      </div>

      <!-- Tab Content Card -->
      <div class="premium-card p-0 overflow-hidden">
        <div class="card-body p-0">

          <!-- TAB (1) الرقم Table -->
          <div *ngIf="activeTab === 'numbers'" class="animate-in fade-in duration-300">
            <div class="overflow-x-auto">
              <table class="premium-table">
                <thead>
                  <tr>
                    <th class="text-center w-16">#</th>
                    <th>الرقم</th>
                    <th>العلاقة</th>
                    <th>المصدر</th>
                    <th class="text-center">الحالة</th>
                  </tr>
                </thead>
                <tbody>
                  <tr *ngFor="let row of numbers; let i = index">
                    <td class="text-center text-slate-400 font-mono text-xs">{{ i + 1 }}</td>
                    <td class="font-bold text-slate-700">{{ row.phone }}</td>
                    <td>{{ row.relation }}</td>
                    <td>{{ row.source }}</td>
                    <td class="text-center">
                      <span class="px-2 py-1 rounded-full text-[10px] font-bold" [ngClass]="{
                                'bg-emerald-100 text-emerald-700': row.status === 'نشط',
                                'bg-slate-100 text-slate-600': row.status !== 'نشط'
                              }">
                        {{ row.status }}
                      </span>
                    </td>
                  </tr>
                  <tr *ngIf="!numbers || numbers.length === 0">
                    <td colspan="5" class="text-center py-4 text-slate-500">لا توجد أرقام مسجلة</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- TAB (2) إضافة رقم Form -->
          <div *ngIf="activeTab === 'add'" class="p-6 animate-in slide-in-from-bottom-2 duration-300">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl">
              <div class="form-field">
                <label class="form-label text-xs uppercase tracking-wider text-slate-500 font-bold mb-1">رقم
                  الهاتف</label>
                <input type="text" class="premium-input" [(ngModel)]="addForm.phone" name="phone"
                  placeholder="أدخل الرقم..." />
              </div>
              <div class="form-field">
                <label class="form-label text-xs uppercase tracking-wider text-slate-500 font-bold mb-1">العلاقة</label>
                <input type="text" class="premium-input" [(ngModel)]="addForm.relation" name="relation"
                  placeholder="مثل: صاحب الرقم، أخ، أب..." />
              </div>
              <div class="form-field">
                <label class="form-label text-xs uppercase tracking-wider text-slate-500 font-bold mb-1">المصدر</label>
                <input type="text" class="premium-input" [(ngModel)]="addForm.source" name="source"
                  placeholder="تحديد المصدر..." />
              </div>
              <div class="form-field">
                <label class="form-label text-xs uppercase tracking-wider text-slate-500 font-bold mb-1">الحالة</label>
                <select [(ngModel)]="addForm.status" name="status"
                  class="premium-input bg-white cursor-pointer hover:bg-slate-50 transition-colors">
                  <option value="نشط">نشط</option>
                  <option value="غير نشط">غير نشط</option>
                  <option value="مغلق">مغلق</option>
                </select>
              </div>
              <div class="md:col-span-2 flex justify-end gap-3 mt-4">
                <button class="premium-btn premium-btn-secondary px-8" (click)="activeTab = 'numbers'">إلغاء</button>
                <button class="premium-btn premium-btn-primary px-8" (click)="saveNumber()">💾 حفظ الرقم</button>
              </div>
            </div>
          </div>


        </div>
      </div>
    </div>
  </div>

  <!-- Negotiation Row -->
  <div class="grid grid-cols-12 gap-4 mt-6">

    <!-- Negotiation Method & Review -->
    <div class="col-span-12 lg:col-span-4 premium-card p-0">
      <div class="card-header py-2 px-3">
        <h3 class="text-sm font-bold">وسيلة التفاوض</h3>
      </div>
      <div class="card-body p-3">
        <div class="grid grid-cols-2 gap-2 mb-2">
          <ng-container *ngFor="let row of negotiationMethodsRows">
            <button
              class="premium-btn py-2 px-1 text-[11px] font-bold rounded-lg border transition-all duration-200 shadow-sm"
              [class.bg-primary]="selectedAction === row.left" [class.border-primary]="selectedAction === row.left"
              [class.text-white]="selectedAction === row.left" [class.bg-white]="selectedAction !== row.left"
              [class.dark:bg-slate-800]="selectedAction !== row.left"
              [class.border-slate-200]="selectedAction !== row.left"
              [class.dark:border-slate-700]="selectedAction !== row.left"
              [class.text-slate-700]="selectedAction !== row.left"
              [class.dark:text-slate-300]="selectedAction !== row.left" (click)="selectAction(row.left)">
              {{ row.left }}
            </button>
            <button
              class="premium-btn py-2 px-1 text-[11px] font-bold rounded-lg border transition-all duration-200 shadow-sm"
              [class.bg-primary]="selectedAction === row.right" [class.border-primary]="selectedAction === row.right"
              [class.text-white]="selectedAction === row.right" [class.bg-white]="selectedAction !== row.right"
              [class.dark:bg-slate-800]="selectedAction !== row.right"
              [class.border-slate-200]="selectedAction !== row.right"
              [class.dark:border-slate-700]="selectedAction !== row.right"
              [class.text-slate-700]="selectedAction !== row.right"
              [class.dark:text-slate-300]="selectedAction !== row.right" (click)="selectAction(row.right)">
              {{ row.right }}
            </button>
          </ng-container>
        </div>
        <div class="mt-2 text-center">
          <button class="premium-btn premium-btn-outline w-full py-1.5 text-xs">تحليل الإفادات</button>
        </div>
      </div>
    </div>

    <!-- Negotiation Outcome -->
