                    <option [ngValue]="null">اختر الحالة...</option>
                    <option *ngFor="let item of lookupLists.claim" [ngValue]="item.id">{{item.name}}</option>
                  </select>
                  <button class="mini-save-btn"
                    (click)="onLookupSelected({id: selectedPerson.classification.claimStatusId, name: ''}, 'claim')">
                    <span>💾</span>
                  </button>
                </div>
                <div class="status-history-area">
                  <div class="micro-history-container custom-scrollbar overflow-y-auto mt-2">
                    <table class="micro-history-table">
                      <thead>
                        <tr>
                          <th>التاريخ</th>
                          <th>الموظف</th>
                          <th>الحالة</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr *ngFor="let h of categoryHistories['claim']">
                          <td>{{h.dateAdded | date:'dd/MM'}}</td>
                          <td class="truncate max-w-[50px]" [title]="h.userName">{{h.userName}}</td>
                          <td><span class="status-badge-mini bg-emerald-50 text-emerald-600">{{h.statusName}}</span>
                          </td>
                        </tr>
                        <tr *ngIf="!categoryHistories['claim']?.length">
                          <td colspan="3" class="text-center py-2 text-slate-400 italic text-[10px]">لا يوجد سجل</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                  <div class="flex justify-center mt-2" *ngIf="(categoryHistories['claim']?.length || 0) > 2">
                    <button
                      class="text-[10px] font-bold text-emerald-500 hover:text-emerald-700 bg-emerald-50/50 px-3 py-1 rounded-lg transition-all active:scale-95"
                      (click)="openFullHistory('حالة المديونية', categoryHistories['claim'])">
                      المزيد ({{categoryHistories['claim']?.length || 0}})
                    </button>
                  </div>
                </div>
              </div>

              <!-- (3) Payment Status -->
              <div class="premium-card status-card">
                <div class="status-card-header mb-2">
                  <div class="flex items-center gap-2">
                    <div class="status-icon-box bg-amber-50 text-amber-500">💰</div>
                    <div>
                      <div class="status-label-main text-[11px]">حالة السداد</div>
                      <div class="status-sub-label">Payment Status</div>
                    </div>
                  </div>
                </div>
                <div class="flex gap-2">
                  <select class="premium-input text-[11px] font-bold h-9 flex-grow"
                    [(ngModel)]="selectedPerson.classification.paymentStatusId">
                    <option [ngValue]="null">اختر الحالة...</option>
                    <option *ngFor="let item of lookupLists.payment" [ngValue]="item.id">{{item.name}}</option>
                  </select>
                  <button class="mini-save-btn"
                    (click)="onLookupSelected({id: selectedPerson.classification.paymentStatusId, name: ''}, 'payment')">
                    <span>💾</span>
                  </button>
                </div>
                <div class="status-history-area">
                  <div class="micro-history-container custom-scrollbar overflow-y-auto mt-2">
                    <table class="micro-history-table">
                      <thead>
                        <tr>
                          <th>التاريخ</th>
                          <th>الموظف</th>
                          <th>الحالة</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr *ngFor="let h of categoryHistories['payment']">
                          <td>{{h.dateAdded | date:'dd/MM'}}</td>
                          <td class="truncate max-w-[50px]" [title]="h.userName">{{h.userName}}</td>
                          <td><span class="status-badge-mini bg-amber-50 text-amber-600">{{h.statusName}}</span></td>
                        </tr>
                        <tr *ngIf="!categoryHistories['payment']?.length">
                          <td colspan="3" class="text-center py-2 text-slate-400 italic text-[10px]">لا يوجد سجل</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                  <div class="flex justify-center mt-2" *ngIf="(categoryHistories['payment']?.length || 0) > 2">
                    <button
                      class="text-[10px] font-bold text-amber-500 hover:text-amber-700 bg-amber-50/50 px-3 py-1 rounded-lg transition-all active:scale-95"
                      (click)="openFullHistory('حالة السداد', categoryHistories['payment'])">
                      المزيد ({{categoryHistories['payment']?.length || 0}})
                    </button>
                  </div>
                </div>
              </div>

              <!-- (4) File Status -->
              <div class="premium-card status-card">
                <div class="status-card-header mb-2">
                  <div class="flex items-center gap-2">
                    <div class="status-icon-box bg-purple-50 text-purple-500">📁</div>
                    <div>
                      <div class="status-label-main text-[11px]">حالة الملف</div>
                      <div class="status-sub-label">File Status</div>
                    </div>
                  </div>
                </div>
                <div class="flex gap-2">
                  <select class="premium-input text-[11px] font-bold h-9 flex-grow"
                    [(ngModel)]="selectedPerson.classification.fileStatusId">
                    <option [ngValue]="null">اختر الحالة...</option>
                    <option *ngFor="let item of lookupLists.file" [ngValue]="item.id">{{item.name}}</option>
                  </select>
                  <button class="mini-save-btn"
                    (click)="onLookupSelected({id: selectedPerson.classification.fileStatusId, name: ''}, 'file')">
                    <span>💾</span>
                  </button>
                </div>
                <div class="status-history-area">
                  <div class="micro-history-container custom-scrollbar overflow-y-auto mt-2">
                    <table class="micro-history-table">
                      <thead>
                        <tr>
                          <th>التاريخ</th>
                          <th>الموظف</th>
                          <th>الحالة</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr *ngFor="let h of categoryHistories['file']">
                          <td>{{h.dateAdded | date:'dd/MM'}}</td>
                          <td class="truncate max-w-[50px]" [title]="h.userName">{{h.userName}}</td>
                          <td><span class="status-badge-mini bg-purple-50 text-purple-600">{{h.statusName}}</span></td>
                        </tr>
                        <tr *ngIf="!categoryHistories['file']?.length">
                          <td colspan="3" class="text-center py-2 text-slate-400 italic text-[10px]">لا يوجد سجل</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                  <div class="flex justify-center mt-2" *ngIf="(categoryHistories['file']?.length || 0) > 2">
                    <button
                      class="text-[10px] font-bold text-purple-500 hover:text-purple-700 bg-purple-50/50 px-3 py-1 rounded-lg transition-all active:scale-95"
                      (click)="openFullHistory('حالة الملف', categoryHistories['file'])">
                      المزيد ({{categoryHistories['file']?.length || 0}})
                    </button>
                  </div>
                </div>
              </div>

              <!-- (5) Action Status -->
              <div class="premium-card status-card">
                <div class="status-card-header mb-2">
                  <div class="flex items-center gap-2">
                    <div class="status-icon-box bg-rose-50 text-rose-500">⚡</div>
                    <div>
                      <div class="status-label-main text-[11px]">حالة الإجراءات</div>
                      <div class="status-sub-label">Action Status</div>
                    </div>
                  </div>
                </div>
                <div class="flex gap-2">
                  <select class="premium-input text-[11px] font-bold h-9 flex-grow"
                    [(ngModel)]="selectedPerson.classification.actionStatusId">
                    <option [ngValue]="null">اختر الحالة...</option>
                    <option *ngFor="let item of lookupLists.action" [ngValue]="item.id">{{item.name}}</option>
                  </select>
                  <button class="mini-save-btn"
                    (click)="onLookupSelected({id: selectedPerson.classification.actionStatusId, name: ''}, 'action')">
                    <span>💾</span>
                  </button>
                </div>
                <div class="status-history-area">
                  <div class="micro-history-container custom-scrollbar overflow-y-auto mt-2">
                    <table class="micro-history-table">
                      <thead>
                        <tr>
                          <th>التاريخ</th>
                          <th>الموظف</th>
                          <th>الحالة</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr *ngFor="let h of categoryHistories['action']">
                          <td>{{h.dateAdded | date:'dd/MM'}}</td>
                          <td class="truncate max-w-[50px]" [title]="h.userName">{{h.userName}}</td>
                          <td><span class="status-badge-mini bg-rose-50 text-rose-600">{{h.statusName}}</span></td>
                        </tr>
                        <tr *ngIf="!categoryHistories['action']?.length">
                          <td colspan="3" class="text-center py-2 text-slate-400 italic text-[10px]">لا يوجد سجل</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                  <div class="flex justify-center mt-2" *ngIf="(categoryHistories['action']?.length || 0) > 2">
                    <button
                      class="text-[10px] font-bold text-rose-500 hover:text-rose-700 bg-rose-50/50 px-3 py-1 rounded-lg transition-all active:scale-95"
                      (click)="openFullHistory('الإجراء', categoryHistories['action'])">
                      المزيد ({{categoryHistories['action']?.length || 0}})
                    </button>
                  </div>
                </div>
              </div>

              <!-- (6) Follow-up Status -->
