              [class.bg-slate-600]="selectedResult === 'مطلوب إجراء'"
              [class.border-slate-600]="selectedResult === 'مطلوب إجراء'"
              [class.text-white]="selectedResult === 'مطلوب إجراء'"
              [class.bg-slate-50]="selectedResult !== 'مطلوب إجراء'"
              [class.dark:bg-slate-800]="selectedResult !== 'مطلوب إجراء'"
              [class.border-slate-200]="selectedResult !== 'مطلوب إجراء'"
              [class.dark:border-slate-700]="selectedResult !== 'مطلوب إجراء'"
              [class.text-slate-600]="selectedResult !== 'مطلوب إجراء'"
              [class.dark:text-slate-400]="selectedResult !== 'مطلوب إجراء'"
              (click)="handleResultClick('مطلوب إجراء')">مطلوب إجراء</button>
          </div>
        </div>

        <!-- Advanced Statement Details (New Request) -->
        <div class="mt-4 pt-4 border-t border-slate-100 dark:border-slate-800 space-y-4">
          <h5
            class="text-[10px] font-black uppercase tracking-widest text-slate-400 dark:text-slate-500 flex items-center gap-2 mb-2">
            <i class="fas fa-edit"></i> تفاصيل إضافية للإفادة
          </h5>

          <div class="grid grid-cols-2 gap-3">
            <!-- Phone & Owner -->
            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase">رقم الهاتف المتواصل
                معه</label>
              <div class="relative">
                <input type="text" [(ngModel)]="statementDetails.phoneNumber"
                  class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg h-8 px-2 text-xs font-bold text-blue-600 dark:text-blue-400 focus:outline-none focus:border-blue-500 transition-all"
                  placeholder="رقم الهاتف...">
              </div>
            </div>
            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase">صاحب الهاتف</label>
              <input type="text" [(ngModel)]="statementDetails.phoneOwner"
                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg h-8 px-2 text-xs font-bold text-slate-700 dark:text-slate-300 focus:outline-none focus:border-blue-500 transition-all"
                placeholder="الموكل، الاب، الخ...">
            </div>

            <!-- Next Action & Date -->
            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase">الإجراء القادم</label>
              <input type="text" [(ngModel)]="statementDetails.nextAction"
                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg h-8 px-2 text-xs font-bold text-slate-700 dark:text-slate-300 focus:outline-none focus:border-blue-500 transition-all"
                placeholder="إعادة اتصال، رفع إجراء...">
            </div>
            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase">تاريخ المتابعة</label>
              <input type="date" [(ngModel)]="statementDetails.nextDate"
                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg h-8 px-2 text-xs font-bold text-slate-700 dark:text-slate-300 focus:outline-none focus:border-blue-500 transition-all">
            </div>
          </div>

          <!-- Full-width Notes -->
          <div class="space-y-1.5">
            <label class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase">الملاحظات
              (Notes)</label>
            <textarea [(ngModel)]="statementDetails.notes"
              class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg p-2 text-xs font-semibold text-slate-700 dark:text-slate-200 shadow-inner focus:outline-none focus:border-blue-500 min-h-[50px] resize-none transition-all"
              placeholder="اكتب تفاصيل المكالمة أو أي ملاحظات أخرى هنا..."></textarea>
          </div>
        </div>

        <div
          class="bg-slate-50/80 dark:bg-slate-800/80 mt-4 rounded-xl p-3 border border-slate-100 dark:border-slate-700 transition-all flex items-center justify-between shadow-inner">
          <div class="flex items-center gap-3 text-[11px]">
            <span class="font-bold text-slate-700 dark:text-slate-300">الملخص:</span>
            <span
              class="text-slate-500 dark:text-slate-400 font-medium px-2 py-1 bg-white dark:bg-slate-900 rounded border border-slate-200 dark:border-slate-700 shadow-sm min-w-24 text-center">{{
              selectedAction ? selectedAction : 'اختر وسيلة' }}</span>
            <span class="text-slate-400">—</span>
            <span
              class="text-slate-500 dark:text-slate-400 font-medium px-2 py-1 bg-white dark:bg-slate-900 rounded border border-slate-200 dark:border-slate-700 shadow-sm min-w-32 text-center text-primary dark:text-primary">{{
              selectedResult ? selectedResult : 'النتيجة' }}</span>
          </div>

          <button
            class="premium-btn premium-btn-primary py-1 px-4 text-xs font-bold shadow-md hover:shadow-lg transition-all"
            (click)="triggerSaveStatement()">
            <span class="ml-1 text-sm">💾</span> حفظ
          </button>
        </div>
      </div>
    </div>

</div>
<!-- ===================================== -->
<!--  Bottom Section: Data Grid            -->
<!-- ===================================== -->
<div class="premium-card mt-6">
  <div class="card-body p-0 md:p-4">
    <div class="premium-tabs-container w-full overflow-x-auto mb-4" style="margin-bottom: 1.5rem;">

      <a class="premium-tab" [class.active]="activeSubTabLower === 'notes'" (click)="setSubActiveLower('notes')">
        الملاحظات
      </a>

      <a role="tab" class="premium-tab" [class.active]="activeSubTabLower === 'efada'"
        (click)="setSubActiveLower('efada')">
        الإفادة
      </a>

      <a role="tab" class="premium-tab" [class.active]="activeSubTabLower === 'record'"
        (click)="setSubActiveLower('record')">
        سجل العمليات
      </a>

      <a role="tab" class="premium-tab" [class.active]="activeSubTabLower === 'statusHistory'"
        (click)="setSubActiveLower('statusHistory')">
        سجل تحديثات الحالات
      </a>

      <a role="tab" class="premium-tab" [class.active]="activeSubTabLower === 'executions'"
        (click)="setSubActiveLower('executions')">
        إفادات التنفيذ
      </a>

      <a role="tab" class="premium-tab" [class.active]="activeSubTabLower === 'trader'"
        (click)="setSubActiveLower('trader')">
        إفادات المتداول
      </a>

      <a role="tab" class="premium-tab" [class.active]="activeSubTabLower === 'link'"
        (click)="setSubActiveLower('link')">
        الرابط
      </a>

      <a role="tab" class="premium-tab" [class.active]="activeSubTabLower === 'files'"
        (click)="setSubActiveLower('files')">
        ملفات أخرى
      </a>

      <a role="tab" class="premium-tab" [class.active]="activeSubTabLower === 'results'"
        (click)="setSubActiveLower('results')">
        نتائج البحث
      </a>

      <a role="tab" class="premium-tab" [class.active]="activeSubTabLower === 'secretary'"
        (click)="setSubActiveLower('secretary')">
        السكرتارية
      </a>

      <a role="tab" class="premium-tab" [class.active]="activeSubTabLower === 'autoNumbers'"
        (click)="setSubActiveLower('autoNumbers')">
        أرقام آلية
      </a>
    </div>

    <!-- ====================== CONTENT ======================= -->

    <!-- الملاحظات -->
    <div *ngIf="activeSubTabLower === 'notes'" class="mt-4">
      <div
        class="flex items-center justify-between mb-3 bg-indigo-50/50 dark:bg-indigo-900/10 p-3 rounded-xl border border-indigo-100 dark:border-indigo-800/30">
        <div class="flex items-center gap-2">
          <span class="w-1.5 h-4 bg-indigo-500 rounded-full"></span>
          <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">الملاحظات</h4>
        </div>
        <div class="flex items-center gap-2">
          <button (click)="prevNotesPage()" [disabled]="notesPage === 1"
            class="premium-btn premium-btn-outline px-3 py-1 text-[10px] flex items-center gap-1">
            <span>◀️</span> السابق
          </button>
          <div
            class="px-2 py-1 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 text-[10px] font-bold text-slate-600 dark:text-slate-300 shadow-sm">
            صفحة {{ notesPage }} من {{ Math.ceil(notesTotal / notesPageSize) || 1 }}
          </div>
          <button (click)="nextNotesPage()" [disabled]="notesPage * notesPageSize >= notesTotal"
            class="premium-btn premium-btn-outline px-3 py-1 text-[10px] flex items-center gap-1">
            التالي <span>▶️</span>
          </button>
        </div>
      </div>
      <div
        class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
        <table class="premium-table w-full">
          <thead>
            <tr
              class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الكود</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">التاريخ</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الملاحظات</th>
            </tr>
          </thead>
          <tbody class="text-[11px]">
            <tr *ngFor="let note of notes"
              class="border-b border-slate-50 dark:border-slate-800 hover:bg-slate-50/50 transition-colors">
              <td class="py-2 px-3 font-mono text-slate-400">{{ note.id }}</td>
              <td class="py-2 px-3 text-slate-500" dir="ltr">{{ note.dateAdded | date:'yyyy-MM-dd HH:mm' }}</td>
              <td class="py-2 px-3 text-slate-700 dark:text-slate-300">{{ note.noteText }}</td>
            </tr>
            <tr *ngIf="!notes || notes.length === 0">
              <td colspan="3" class="text-center py-10 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">لا
                توجد ملاحظات مسجلة</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- الإفادة -->
    <div *ngIf="activeSubTabLower === 'efada'" class="mt-4">
      <div
        class="flex items-center justify-between mb-3 bg-emerald-50/50 dark:bg-emerald-900/10 p-3 rounded-xl border border-emerald-100 dark:border-emerald-800/30">
        <div class="flex items-center gap-2">
          <span class="w-1.5 h-4 bg-emerald-500 rounded-full"></span>
          <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">الإفادة</h4>
        </div>
        <div class="flex items-center gap-2">
          <button (click)="prevStatementsPage()" [disabled]="statementsPage === 1"
            class="premium-btn premium-btn-outline px-3 py-1 text-[10px] flex items-center gap-1">
            <span>◀️</span> السابق
          </button>
          <div
            class="px-2 py-1 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 text-[10px] font-bold text-slate-600 dark:text-slate-300 shadow-sm">
            صفحة {{ statementsPage }} من {{ Math.ceil(statementsTotal / statementsPageSize) || 1 }}
          </div>
          <button (click)="nextStatementsPage()" [disabled]="statementsPage * statementsPageSize >= statementsTotal"
            class="premium-btn premium-btn-outline px-3 py-1 text-[10px] flex items-center gap-1">
            التالي <span>▶️</span>
          </button>
        </div>
      </div>
      <div
        class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
        <table class="premium-table w-full">
          <thead>
            <tr
              class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">#</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">تاريخ الإفادة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">النتيجة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الوسيلة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">رقم الهاتف</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">صاحب الهاتف</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المبلغ</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الإجراء القادم</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">تاريخ المتابعة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right w-1/4">الملاحظات</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الموظف</th>
            </tr>
          </thead>
          <tbody class="text-[11px]">
            <tr *ngFor="let ef of callcenterStatements; let i = index"
              class="border-b border-slate-50 dark:border-slate-800 hover:bg-slate-50/80 dark:hover:bg-slate-700/30 transition-colors">
              <td class="py-2 px-3 font-mono text-slate-400">{{ i + 1 }}</td>
              <td class="py-2 px-3 font-bold text-slate-700 dark:text-slate-200">{{ ef.dateAdded | date:'dd/MM/yyyy
                HH:mm' }}</td>
              <td class="py-2 px-3">
                <span
                  class="px-2 py-0.5 rounded-lg bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-300 font-bold border border-blue-100 dark:border-blue-800/50 text-[10px]">
                  {{ ef.connectedStatus }}
                </span>
              </td>
              <td class="py-2 px-3 text-slate-500">{{ ef.contactMethod }}</td>
              <td class="py-2 px-3 font-mono text-indigo-600">{{ ef.phoneNumber }}</td>
              <td class="py-2 px-3 text-slate-500">{{ ef.phoneOwner || '---' }}</td>
              <td class="py-2 px-3 font-black text-emerald-600">{{ (ef.promiseAmount | number) || '0' }}</td>
              <td class="py-2 px-3 font-bold text-indigo-600">{{ ef.nextAction || '---' }}</td>
              <td class="py-2 px-3 text-slate-400">{{ (ef.nextDate | date:'dd/MM/yyyy') || '---' }}</td>
              <td class="py-2 px-3 text-slate-500 italic">"{{ ef.notes || 'بدون ملاحظات' }}"</td>
              <td class="py-2 px-3">
                <div class="flex items-center gap-1">
                  <span
                    class="w-4 h-4 rounded-full bg-slate-100 flex items-center justify-center text-[8px] font-bold text-slate-500 border border-slate-200">{{
                    ef.userAddedName?.charAt(0) }}</span>
                  <span class="font-medium text-slate-500">{{ ef.userAddedName }}</span>
                </div>
              </td>
            </tr>
            <tr *ngIf="!callcenterStatements || callcenterStatements.length === 0">
              <td colspan="11" class="text-center py-12 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">لا
                توجد إفادات مسجلة</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- السجل (Audit History) -->
    <div *ngIf="activeSubTabLower === 'record'" class="mt-4">
      <div
        class="flex items-center justify-between mb-3 bg-slate-50/50 dark:bg-slate-800/50 p-3 rounded-xl border border-slate-200 dark:border-slate-700">
        <h3 class="font-bold text-sm">سجل العمليات</h3>
        <div class="flex items-center gap-2">
          <button (click)="prevAuditsPage()" [disabled]="auditsPage === 1"
            class="premium-btn premium-btn-outline px-3 py-1 text-[10px] flex items-center gap-1">
            <span>◀️</span> السابق
          </button>
          <div
            class="px-2 py-1 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 text-[10px] font-bold text-slate-600 dark:text-slate-300 shadow-sm">
            صفحة {{ auditsPage }} من {{ Math.ceil(auditsTotal / auditsPageSize) || 1 }}
          </div>
          <button (click)="nextAuditsPage()" [disabled]="auditsPage * auditsPageSize >= auditsTotal"
            class="premium-btn premium-btn-outline px-3 py-1 text-[10px] flex items-center gap-1">
            التالي <span>▶️</span>
          </button>
        </div>
      </div>
      <table class="premium-table">
        <thead>
          <tr class="bg-slate-50 dark:bg-slate-800/50 text-[10px] uppercase font-bold text-slate-500">
            <th class="py-2 px-3 border-b border-slate-100 dark:border-slate-700 text-right">التاريخ</th>
            <th class="py-2 px-3 border-b border-slate-100 dark:border-slate-700 text-right">الحدث</th>
            <th class="py-2 px-3 border-b border-slate-100 dark:border-slate-700 text-right">الوصف</th>
            <th class="py-2 px-3 border-b border-slate-100 dark:border-slate-700 text-right">المستخدم</th>
          </tr>
        </thead>
        <tbody class="text-[11px]">
          <tr *ngFor="let audit of audits" class="border-b border-slate-50 dark:border-slate-800">
            <td class="py-2 px-3 font-mono text-slate-400">{{ audit.actionDate | date:'dd/MM/yyyy HH:mm' }}</td>
            <td class="py-2 px-3 font-bold text-blue-600 dark:text-blue-400">{{ audit.action }}</td>
            <td class="py-2 px-3 text-slate-600 dark:text-slate-300">{{ audit.description }}</td>
            <td class="py-2 px-3 font-semibold text-slate-500">{{ audit.userName }}</td>
          </tr>
          <tr *ngIf="audits.length === 0">
            <td colspan="4" class="text-center py-6 text-slate-400 italic bg-slate-50/30 dark:bg-slate-900/10">لا يوجد
              سجل عمليات مسجل لهذه القضية</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- سجل تحديثات الحالات (Status History) -->
    <div *ngIf="activeSubTabLower === 'statusHistory'" class="mt-4">
      <div
        class="flex items-center justify-between mb-4 bg-indigo-50/50 dark:bg-indigo-900/10 p-3 rounded-xl border border-indigo-100 dark:border-indigo-800/30">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center text-white shadow-lg">
            📜
          </div>
          <h3 class="font-bold text-indigo-900 dark:text-indigo-100">سجل تحديثات الحالات</h3>
        </div>
        <div class="flex items-center gap-2">
          <button (click)="prevHistoryPage()" [disabled]="historyPage === 1"
            class="premium-btn premium-btn-outline px-3 py-1.5 text-xs flex items-center gap-1">
            <span>◀️</span> السابق
          </button>
          <div
            class="px-3 py-1.5 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 text-xs font-bold text-slate-600 dark:text-slate-300 shadow-sm">
            صفحة {{ historyPage }} من {{ Math.ceil(statusesTotal / historyPageSize) || 1 }}
          </div>
          <button (click)="nextHistoryPage()" [disabled]="historyPage * historyPageSize >= statusesTotal"
            class="premium-btn premium-btn-outline px-3 py-1.5 text-xs flex items-center gap-1">
            التالي <span>▶️</span>
          </button>
        </div>
      </div>
      <div
        class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800">
        <table class="premium-table w-full">
          <thead>
            <tr
              class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">#</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">التاريخ والوقت</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الموظف</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">نوع الحالة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الحالة الجديدة</th>
            </tr>
          </thead>
          <tbody class="text-[11px]">
            <tr *ngFor="let s of statuses; let i = index"
              class="border-b border-slate-50 dark:border-slate-800 hover:bg-slate-50/80 dark:hover:bg-slate-700/30 transition-colors">
              <td class="py-3 px-4 font-mono text-slate-400">{{ (historyPage-1)*historyPageSize + i + 1 }}</td>
              <td class="py-3 px-4 font-bold text-slate-700 dark:text-slate-200">{{ s.dateAdded | date:'dd/MM/yyyy
                HH:mm:ss' }}</td>
              <td class="py-3 px-4">
                <div class="flex items-center gap-2">
                  <div
                    class="w-6 h-6 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-[10px] text-slate-500 font-bold border border-slate-200 dark:border-slate-600">
                    {{ s.userName?.charAt(0) || 'U' }}
                  </div>
                  <span class="font-medium text-slate-600 dark:text-slate-400">{{ s.userName || 'موظف النظام' }}</span>
                </div>
              </td>
              <td class="py-3 px-4">
                <span
                  class="px-2 py-0.5 rounded text-[10px] bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-800/50 font-bold">
                  {{ splitStatus(s.status).type }}
                </span>
              </td>
              <td class="py-3 px-4">
                <span
                  class="px-3 py-1 rounded-lg bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 font-bold border border-emerald-100 dark:border-emerald-800/50 shadow-sm">
                  {{ splitStatus(s.status).value }}
                </span>
              </td>
            </tr>
            <tr *ngIf="!statuses || statuses.length === 0">
              <td colspan="5" class="text-center py-12 text-slate-400 italic bg-slate-50/30 dark:bg-slate-900/5">
                <div class="flex flex-col items-center gap-2">
                  <span class="text-2xl">⏳</span>
                  <span>لا يوجد سجل تحديثات مسجل لهذه الحالات حتى الآن</span>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- executions -->
    <div *ngIf="activeSubTabLower === 'executions'" class="mt-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-1.5 h-4 bg-rose-500 rounded-full"></span>
        <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">تنفيذات</h4>
      </div>
      <div
        class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
        <table class="premium-table w-full">
          <thead>
            <tr
              class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">#</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">التاريخ</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">آخر إجراء</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">تاريخ آخر إجراء</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الإجراء القادم</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">تاريخ الإجراء القادم
              </th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">مكان الملف</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right w-1/4">ملاحظات</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المستخدم</th>
            </tr>
          </thead>
          <tbody class="text-[11px]">
            <tr *ngFor="let exec of executionsData; let i = index"
              class="border-b border-slate-50 hover:bg-slate-50/50 transition-colors">
              <td class="py-2 px-3 text-slate-400">{{ i + 1 }}</td>
              <td class="py-2 px-3 text-slate-500">{{ exec.date }}</td>
              <td class="py-2 px-3 font-bold text-rose-600">{{ exec.lastAction }}</td>
              <td class="py-2 px-3 text-slate-400">{{ exec.lastActionDate }}</td>
              <td class="py-2 px-3 font-bold text-indigo-600">{{ exec.nextAction }}</td>
              <td class="py-2 px-3 text-slate-400">{{ exec.nextActionDate }}</td>
              <td class="py-2 px-3 text-slate-500">{{ exec.fileLocation }}</td>
              <td class="py-2 px-3 text-slate-500 italic">{{ exec.notes }}</td>
              <td class="py-2 px-3 font-medium text-slate-600">{{ exec.user }}</td>
            </tr>
            <tr *ngIf="!executionsData || executionsData.length === 0">
              <td colspan="9" class="text-center py-10 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">لا
                توجد بيانات تنفيذ متاحة</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>


    <!-- trader -->
    <div *ngIf="activeSubTabLower === 'trader'" class="mt-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-1.5 h-4 bg-amber-500 rounded-full"></span>
        <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">جلسات المتداول</h4>
      </div>
      <div
        class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
        <table class="premium-table w-full">
          <thead>
            <tr
              class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">#</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">تاريخ الإفادة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">نوع الجلسة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">القرار</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الجلسة القادمة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">توقيت الخبراء</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">ملاحظات الجلسة</th>
            </tr>
          </thead>
          <tbody class="text-[11px]">
            <tr *ngFor="let session of traderData; let i = index"
              class="border-b border-slate-50 hover:bg-slate-50/50 transition-colors">
              <td class="py-2 px-3 text-slate-400">{{ i + 1 }}</td>
              <td class="py-2 px-3 text-slate-500">{{ session.efadaDate }}</td>
              <td class="py-2 px-3 font-bold text-amber-600">{{ session.sessionType }}</td>
              <td class="py-2 px-3 text-slate-700">{{ session.decision }}</td>
              <td class="py-2 px-3 font-bold text-indigo-600">{{ session.nextSession }}</td>
              <td class="py-2 px-3 text-slate-400">{{ session.expertsTime }}</td>
              <td class="py-2 px-3 text-slate-500 italic">{{ session.notes }}</td>
            </tr>
            <tr *ngIf="!traderData || traderData.length === 0">
              <td colspan="7" class="text-center py-10 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">لا
                توجد جلسات مسجلة</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- link-->
    <div *ngIf="activeSubTabLower === 'link'" class="mt-4">
      <h3 class="font-bold mb-2">link</h3>
      <p>لينك</p>
    </div>

    <!-- files -->
    <div *ngIf="activeSubTabLower === 'files'" class="mt-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-1.5 h-4 bg-blue-500 rounded-full"></span>
        <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">ملفات المديونية</h4>
      </div>
      <div
        class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
        <table class="premium-table w-full">
          <thead>
            <tr
              class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">#</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الكود</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">سبب المديونية</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">حالة الملف</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الموكل</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">رقم العقد</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">قيمة المطالبة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المدفوع</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المتبقي</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">رقم الباتش</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الموظف/المحامي</th>
            </tr>
          </thead>
          <tbody class="text-[11px]">
            <tr *ngFor="let file of clientRows; let i = index"
              class="border-b border-slate-50 dark:border-slate-800 hover:bg-blue-50/30 transition-colors">
              <td class="py-2 px-3 font-mono text-slate-400">{{ i + 1 }}</td>
              <td class="py-2 px-3 font-bold text-indigo-600">{{ file.code }}</td>
              <td class="py-2 px-3 text-slate-500">{{ file.debtReason }}</td>
              <td class="py-2 px-3">
                <span
                  class="px-2 py-0.5 rounded-lg bg-emerald-50 text-emerald-600 border border-emerald-100 text-[10px] font-bold">
                  {{ file.fileStatus }}
                </span>
              </td>
              <td class="py-2 px-3 text-slate-400">{{ file.client }}</td>
              <td class="py-2 px-3 font-mono text-slate-400">{{ file.contractNum }}</td>
              <td class="py-2 px-3 font-bold text-slate-700">{{ (file.claim | number) || '0' }}</td>
              <td class="py-2 px-3 font-bold text-emerald-600">{{ (file.paid | number) || '0' }}</td>
              <td class="py-2 px-3 font-black text-rose-600">{{ (file.remaining | number) || '0' }}</td>
              <td class="py-2 px-3 font-mono text-slate-400">{{ file.batch }}</td>
              <td class="py-2 px-3 text-slate-500">{{ file.lawyerName }}</td>
            </tr>
            <tr *ngIf="!clientRows || clientRows.length === 0">
              <td colspan="11" class="text-center py-12 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">لا
                توجد ملفات مديونية متاحة</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>


    <!-- results-->
    <div *ngIf="activeSubTabLower === 'results'" class="mt-4">
      <h3 class="font-bold mb-2">results</h3>
      <p>سيتم عرض نتائج البحث بعد اختيار الرقم…</p>
    </div>

    <!-- secretary -->
    <div *ngIf="activeSubTabLower === 'secretary'" class="mt-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-1.5 h-4 bg-indigo-500 rounded-full"></span>
        <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">السكرتارية</h4>
      </div>
      <div
        class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
        <table class="premium-table w-full">
          <thead>
            <tr
              class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">التاريخ</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الملاحظة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الموظف</th>
            </tr>
          </thead>
          <tbody class="text-[11px]">
            <tr *ngFor="let sec of notes" class="border-b border-slate-50 hover:bg-slate-50/50 transition-colors">
              <td class="py-2 px-3 font-mono text-slate-400">{{ sec.dateAdded | date:'dd/MM/yyyy HH:mm' }}</td>
              <td class="py-2 px-3 text-slate-700 dark:text-slate-300 leading-relaxed">{{ sec.noteText }}</td>
              <td class="py-2 px-3">
                <div class="flex items-center gap-1">
                  <span
                    class="w-4 h-4 rounded-full bg-indigo-50 flex items-center justify-center text-[8px] font-bold text-indigo-600 border border-indigo-100">{{
                    sec.userName?.charAt(0) || 'S' }}</span>
                  <span class="font-medium text-slate-500">{{ sec.userName || 'System' }}</span>
                </div>
              </td>
            </tr>
            <tr *ngIf="!notes || notes.length === 0">
              <td colspan="3" class="text-center py-10 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">لا
                توجد ملاحظات سكرتارية</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>


    <!-- autoNumbers -->
    <div *ngIf="activeSubTabLower === 'autoNumbers'" class="mt-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-1.5 h-4 bg-indigo-500 rounded-full"></span>
        <h4 class="text-xs font-black text-slate-500 uppercase tracking-wider">أرقام آلية</h4>
      </div>
      <div
        class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800 overflow-x-auto">
        <table class="premium-table w-full">
          <thead>
            <tr
              class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">#</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الرقم</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">النوع</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المرجع</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المطالب/الخصم</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">ملاحظة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">تاريخ الإضافة</th>
            </tr>
          </thead>
          <tbody class="text-[11px]">
            <tr *ngFor="let auto of autoNumbers; let i = index"
              class="border-b border-slate-50 dark:border-slate-800 hover:bg-indigo-50/30 transition-colors">
              <td class="py-2 px-3 text-slate-400">{{ i + 1 }}</td>
              <td class="py-2 px-3 font-mono font-bold text-indigo-600">{{ auto.autoNumberValue }}</td>
              <td class="py-2 px-3 text-slate-500">{{ auto.type || '---' }}</td>
              <td class="py-2 px-3 text-slate-400 font-mono text-[10px]">{{ auto.caseRef || '---' }}</td>
              <td class="py-2 px-3 font-semibold text-slate-600 dark:text-slate-300">{{ auto.claimant || '---' }}</td>
              <td class="py-2 px-3 text-slate-500 italic">{{ auto.note || '---' }}</td>
              <td class="py-2 px-3 text-slate-400">{{ auto.dateAdded | date:'dd/MM/yyyy' }}</td>
            </tr>
            <tr *ngIf="!autoNumbers || autoNumbers.length === 0">
              <td colspan="7" class="text-center py-12 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">لا
                توجد أرقام آلية مسجلة</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    </div>
  </div>
</div>
</div>
</div>
</div>
 
 
<!-- searchNumbers -->


<div *ngIf="activeMainTab === 'searchNumbers'">
  <div class="flex h-full gap-4 p-2">

    <!-- 1. لوحة التحكم والإدخال (يمين الشاشة) -->
    <div
      class="w-100 flex flex-col gap-3 shrink-0 bg-gray-50 p-3 border border-gray-300 rounded-lg shadow-md overflow-y-auto">

      <!-- قسم الخصم والمدني وتاريخ الانتهاء -->
      <div class="space-y-2 pb-3 ">
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-12">الخصم :</label>
          <input type="text" [(ngModel)]="searchNumbersForm.discount"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>

        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-12">المدني :</label>
          <input type="text" [(ngModel)]="searchNumbersForm.civilID" (keyup.enter)="onSearchNumbers()"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>

        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-24">تاريخ انتهاء المدنية :</label>
          <input type="date" [(ngModel)]="searchNumbersForm.civilEndDate"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>
      </div>

      <!-- A. بيانات الكفيل (القسم الثاني في الصورة) -->
      <div class="space-y-2 border-b pb-3 border-gray-300">
        <h4 class="font-bold text-gray-800 text-sm border-b border-gray-400 pb-1">بيانات الكفيل</h4>
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-16">الكفيل</label>
          <input type="text" [(ngModel)]="searchNumbersForm.guarantor"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-16">الغاكس</label>
          <input type="text" [(ngModel)]="searchNumbersForm.fax"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-28">رقم السجل التجاري</label>
          <input type="text" [(ngModel)]="searchNumbersForm.commercialReg"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-28">رقم مدني الشركة</label>
          <input type="text" [(ngModel)]="searchNumbersForm.companyCivil"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-28">نوع العضوية</label>
          <input type="text" [(ngModel)]="searchNumbersForm.membership"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-16">الهاتف</label>
          <input type="text" [(ngModel)]="searchNumbersForm.phone"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-16">البريد</label>
          <input type="text" [(ngModel)]="searchNumbersForm.email"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>
        <!-- شركاء 1، 2، 3 -->
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-16">شريك 1</label>
          <input type="text" [(ngModel)]="searchNumbersForm.partner1"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-16">شريك 2</label>
          <input type="text" [(ngModel)]="searchNumbersForm.partner2"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-16">شريك 3</label>
          <input type="text" [(ngModel)]="searchNumbersForm.partner3"
            class="input input-xs input-bordered w-full rounded-none h-6 border-gray-400" />
        </div>

        <!-- أزرار الإكسل والحفظ (الأخضر) -->
        <div class="flex justify-center gap-2 shrink-0 mt-3">
          <button
            class="btn btn-sm bg-green-700 hover:bg-green-800 text-white shadow-sm rounded-none h-8 min-h-0 px-6">إكسل</button>
          <button class="btn btn-sm bg-green-700 hover:bg-green-800 text-white shadow-sm rounded-none h-8 min-h-0 px-6"
            (click)="onSave()">حفظ</button>
        </div>
      </div>

      <!-- B. بيانات البحث عن الأرقام (القسم السفلي في الصورة) -->
      <div class="space-y-2 border-t pt-3 border-gray-300">
        <label class="font-bold text-gray-700 block">رقم الهواتف</label>
        <input type="text" class="input input-xs input-bordered w-full rounded-none  h-6" />

        <label class="font-bold text-gray-700 block">المدني لمالك الهواتف</label>
        <input type="text" class="input input-xs input-bordered w-full rounded-none  h-6" />

        <label class="font-bold text-gray-700 block">المستخدم</label>
        <select
          class="select select-xs select-bordered w-full rounded-none border-gray-400 h-6 min-h-0 bg-white"></select>

        <label class="font-bold text-gray-700 block">المصدر</label>
        <select
          class="select select-xs select-bordered w-full rounded-none border-gray-400 h-6 min-h-0 bg-white"></select>

        <label class="font-bold text-gray-700 block">التصنيف</label>
        <select
          class="select select-xs select-bordered w-full rounded-none border-gray-400 h-6 min-h-0 bg-white"></select>

        <label class="font-bold text-gray-700 block">نوع الخط</label>
        <select
          class="select select-xs select-bordered w-full rounded-none border-gray-400 h-6 min-h-0 bg-white"></select>

        <label class="font-bold text-gray-700 block">حالة الرقم</label>
        <select
          class="select select-xs select-bordered w-full rounded-none border-gray-400 h-6 min-h-0 bg-white"></select>
      </div>

      <!-- C. أزرار التحكم السفلية -->
      <div class="flex justify-center gap-2 shrink-0 mt-3">
        <button
          class="btn btn-xs bg-gray-200 hover:bg-gray-300 text-gray-700 border-gray-400 shadow-sm rounded-none h-6 min-h-0 px-4">تراجع</button>
        <button
          class="btn btn-xs bg-gray-200 hover:bg-gray-300 text-gray-700 border-gray-400 shadow-sm rounded-none h-6 min-h-0 px-4">تعديل</button>
        <button
          class="btn btn-xs bg-gray-200 hover:bg-gray-300 text-gray-700 border-gray-400 shadow-sm rounded-none h-6 min-h-0 px-4">حفظ</button>
      </div>
    </div>

    <!-- 2. منطقة الجدول والإحصائيات (وسط وشمال الشاشة) -->
    <div class="flex-grow flex flex-col gap-4">

      <!-- A. الجدول الرئيسي -->
      <div
        class="flex-grow overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800">
        <div class="overflow-auto h-full">
          <table class="premium-table w-full">
            <thead>
              <tr
                class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
                <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الرقم</th>
                <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المدني</th>
                <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المستخدم</th>
                <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">التصنيف</th>
                <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المصدر</th>
                <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">نوع الخط</th>
                <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">تاريخ الإضافة</th>
                <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">حالة الرقم</th>
              </tr>
            </thead>
            <tbody class="text-[11px]">
              <tr *ngFor="let row of numbersSearchResults"
                class="border-b border-slate-50 dark:border-slate-800 hover:bg-slate-50/50 transition-colors">
                <td class="py-2 px-3 font-mono font-bold text-indigo-600">{{ row.number }}</td>
                <td class="py-2 px-3 text-slate-500 font-mono">{{ row.civilID }}</td>
                <td class="py-2 px-3 text-slate-500">{{ row.user }}</td>
                <td class="py-2 px-3 text-slate-500">{{ row.classification }}</td>
                <td class="py-2 px-3 text-slate-500">{{ row.source }}</td>
                <td class="py-2 px-3 text-slate-500">{{ row.type }}</td>
                <td class="py-2 px-3 text-slate-400 font-mono">{{ row.date }}</td>
                <td class="py-2 px-3">
                  <span
                    class="px-2 py-0.5 rounded bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-[10px] font-bold text-slate-500">
                    {{ row.status }}
                  </span>
                </td>
              </tr>
              <tr *ngIf="!numbersSearchResults || numbersSearchResults.length === 0">
                <td colspan="8" class="text-center py-12 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">
                  لا توجد نتائج بحث متاحة
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- B. الجداول السفلية (3 قوائم) -->
      <div class="flex gap-4 shrink-0 h-48 mb-2">
        <!-- الجدول الأيمن -->
        <div
          class="flex-1 overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800">
          <table class="premium-table w-full">
            <thead>
              <tr
                class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
                <th class="py-2 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">العدد</th>
                <th class="py-2 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">نوع الخط</th>
              </tr>
            </thead>
            <tbody class="text-[11px]">
              <tr *ngFor="let row of bottomTable1"
                class="border-b border-slate-50 hover:bg-slate-50/50 transition-colors">
                <td class="py-2 px-4 font-bold text-indigo-600">{{row.count}}</td>
                <td class="py-2 px-4 text-slate-500">{{row.type}}</td>
              </tr>
              <tr *ngIf="!bottomTable1 || bottomTable1.length === 0">
                <td colspan="2" class="text-center py-6 text-slate-400 italic">لا توجد إحصائيات</td>
              </tr>
            </tbody>
          </table>
        </div>
        <!-- الجدول الأوسط -->
        <div
          class="flex-1 overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800">
          <table class="premium-table w-full">
            <thead>
              <tr
                class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
                <th class="py-2 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">العدد</th>
                <th class="py-2 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">المصدر</th>
              </tr>
            </thead>
            <tbody class="text-[11px]">
              <tr *ngFor="let row of bottomTable2"
                class="border-b border-slate-50 hover:bg-slate-50/50 transition-colors">
                <td class="py-2 px-4 font-bold text-indigo-600">{{row.count}}</td>
                <td class="py-2 px-4 text-slate-500">{{row.source}}</td>
              </tr>
              <tr *ngIf="!bottomTable2 || bottomTable2.length === 0">
                <td colspan="2" class="text-center py-6 text-slate-400 italic">لا توجد إحصائيات</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>

</div>

<!-- menuSearch -->
<div *ngIf="activeMainTab === 'menuSearch'" dir="rtl" class="p-6 rounded-lg shadow-md w-full"
  style="background-color: var(--surface-ground); border: 1px solid var(--surface-border);">

  <h3 class="text-xl font-bold mb-6" style="color: var(--text-color);">قائمة البحث</h3>

  <!-- النموذج الرئيسي -->
  <div class="grid grid-cols-2 gap-4 w-full max-w-3xl text-sm">

    <!-- الاسم بالكامل -->
    <div class="col-span-2 flex items-center gap-4">
      <label class="w-32 font-bold" style="color: var(--text-color);">الاسم بالكامل</label>
      <input type="text" [(ngModel)]="menuSearchForm.fullName" name="fullName" (keyup.enter)="searchMenu()"
        class="input input-sm w-full rounded-none"
        style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);" />
    </div>

    <!-- الاسم - الأب - الجد - العائلة -->
    <div class="col-span-2 grid grid-cols-12 gap-4 items-center">

      <label class="w-32 font-bold col-span-2 flex items-center" style="color: var(--text-color);">الاسم</label>

      <input type="text" [(ngModel)]="menuSearchForm.firstName" placeholder="الاسم" name="firstName"
        (keyup.enter)="searchMenu()" class="col-span-2 input input-sm rounded-none"
        style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);" />

      <input type="text" [(ngModel)]="menuSearchForm.middleName" placeholder="الأب" name="middleName"
        (keyup.enter)="searchMenu()" class="col-span-2 input input-sm rounded-none"
        style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);" />

      <input type="text" [(ngModel)]="menuSearchForm.lastName" placeholder="الجد" name="lastName"
        (keyup.enter)="searchMenu()" class="col-span-2 input input-sm rounded-none"
        style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);" />

      <label class="font-bold col-span-2 flex items-center" style="color: var(--text-color);">العائلة</label>

      <select [(ngModel)]="menuSearchForm.familyName" name="familyName" class="col-span-2 select select-sm rounded-none"
        style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);">
        <option value="" disabled selected>--- اختر العائلة ---</option>
        <option *ngFor="let family of familyList" [value]="family">
          {{ family }}
        </option>
      </select>
    </div>

    <!-- المدني + الموحد -->
    <div class="col-span-2 grid grid-cols-8 gap-4 items-center">

      <label class="w-32 font-bold col-span-2" style="color: var(--text-color);">المدني</label>
      <input type="text" [(ngModel)]="menuSearchForm.civilId" name="civilId" (keyup.enter)="searchMenu()"
        class="col-span-2 input input-sm rounded-none"
        style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);" />

      <label class="w-32 font-bold col-span-2" style="color: var(--text-color);">الموحد</label>
      <input type="text" [(ngModel)]="menuSearchForm.unifiedNumber" name="unifiedNumber" (keyup.enter)="searchMenu()"
        class="col-span-2 input input-sm rounded-none"
        style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);" />
    </div>

    <!-- الرقم -->
    <div class="col-span-2 flex items-center gap-4">
      <label class="w-32 font-bold" style="color: var(--text-color);">الرقم</label>
      <input type="text" [(ngModel)]="menuSearchForm.phone" name="phone" (keyup.enter)="searchMenu()"
        class="input input-sm w-full rounded-none"
        style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);" />
    </div>

    <!-- العنوان -->
    <div class="col-span-2 flex items-center gap-4">
      <label class="w-32 font-bold" style="color: var(--text-color);">العنوان</label>
      <input type="text" [(ngModel)]="menuSearchForm.address" name="address" (keyup.enter)="searchMenu()"
        class="input input-sm w-full rounded-none"
        style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);" />
    </div>

  </div>

  <!-- الأزرار -->
  <div class="flex gap-3 mt-6 w-full max-w-3xl">
    <button class="btn btn-sm rounded-none shadow-sm h-8 min-h-0 px-6"
      style="background-color: var(--surface-hover); color: var(--text-color); border-color: var(--surface-border);"
      (click)="searchMenu()">بحث</button>

    <button class="btn btn-sm rounded-none shadow-sm h-8 min-h-0 px-6"
      style="background-color: var(--surface-hover); color: var(--text-color); border-color: var(--surface-border);">
      إضافة
    </button>

    <button class="btn btn-sm rounded-none shadow-sm h-8 min-h-0 px-6"
      style="background-color: var(--surface-hover); color: var(--text-color); border-color: var(--surface-border);"
      (click)="resetMenuSearch()">تراجع</button>
  </div>

</div>

<!--  FeesAndCollection -->
<div *ngIf="activeMainTab === 'FeesAndCollection'">
  <h2 class="text-xl font-bold"> العمولات و التحصيل</h2>
</div>

<!-- notes -->
<div *ngIf="activeMainTab === 'notes'">
  <h2 class="text-xl font-bold">الملاحظات</h2>
</div>

<!-- preview -->
<div *ngIf="activeMainTab === 'preview'">
  <h2 class="text-xl font-bold">preview</h2>
</div>

<!-- newFiles -->
<div *ngIf="activeMainTab === 'newFiles'">
  <h2 class="text-xl font-bold">newFiles</h2>
</div>

<!-- statements -->
<div *ngIf="activeMainTab === 'statements'">
  <div class="flex flex-col h-full overflow-hidden">

    <!-- 1. شريط البحث والفلترة -->
    <div class="flex flex-wrap justify-between items-center p-2 rounded-lg shadow-sm shrink-0 mb-3 gap-2"
      style="background-color: var(--surface-section); border: 1px solid var(--surface-border);">

      <!-- حقول التاريخ -->
      <div class="flex items-center gap-4 text-xs shrink-0">
        <div class="flex items-center gap-2 text-xs">
          <label class="font-bold text-gray-700 w-16" style="color: var(--text-color);">المدني / الاسم</label>
          <input type="text" [(ngModel)]="searchStatementsForm.name" (keyup.enter)="searchStatements()"
            class="input input-xs input-bordered w-full rounded-none h-6"
            style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);" />
        </div>
        <div class="flex items-center gap-1">
          <label class="font-bold" style="color: var(--text-color);">من تاريخ</label>
          <input type="date" [(ngModel)]="searchStatementsForm.fromDate" (keyup.enter)="searchStatements()"
            class="input input-xs input-bordered rounded-none h-6"
            style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);" />
        </div>
        <div class="flex items-center gap-1">
          <label class="font-bold" style="color: var(--text-color);">الى تاريخ</label>
          <input type="date" [(ngModel)]="searchStatementsForm.toDate" (keyup.enter)="searchStatements()"
            class="input input-xs input-bordered rounded-none h-6"
            style="border-color: var(--surface-border); background-color: var(--surface-premium-card); color: var(--text-color);" />
        </div>

        <!-- زر البحث العام -->
        <button class="btn btn-xs premium-btn-primary rounded-none h-6 min-h-0 px-4" (click)="searchStatements()">بحث
          عام</button>
      </div>

      <!-- أزرار الفلترة السريعة -->
      <div class="flex items-center gap-2 text-xs">

        <button class="btn btn-xs rounded-none h-6 min-h-0 px-4"
          [style.background-color]="activeFilter === 'statements' ? 'var(--primary-color)' : 'var(--surface-hover)'"
          [style.color]="activeFilter === 'statements' ? '#ffffff' : 'var(--text-color)'"
          [style.border-color]="'var(--surface-border)'" (click)="setFilterAndSearch('statements')">
          إفادات
        </button>

        <button class="btn btn-xs rounded-none h-6 min-h-0 px-4"
          [style.background-color]="activeFilter === 'review' ? 'var(--primary-color)' : 'var(--surface-hover)'"
          [style.color]="activeFilter === 'review' ? '#ffffff' : 'var(--text-color)'"
          [style.border-color]="'var(--surface-border)'" (click)="setFilterAndSearch('review')">
          مراجعة
        </button>

        <button class="btn btn-xs rounded-none h-6 min-h-0 px-4"
          [style.background-color]="activeFilter === 'paid' ? 'var(--primary-color)' : 'var(--surface-hover)'"
          [style.color]="activeFilter === 'paid' ? '#ffffff' : 'var(--text-color)'"
          [style.border-color]="'var(--surface-border)'" (click)="setFilterAndSearch('paid')">
          السداد
        </button>

        <button class="btn btn-xs rounded-none h-6 min-h-0 px-4"
          [style.background-color]="activeFilter === 'group_paid' ? 'var(--primary-color)' : 'var(--surface-hover)'"
          [style.color]="activeFilter === 'group_paid' ? '#ffffff' : 'var(--text-color)'"
          [style.border-color]="'var(--surface-border)'" (click)="setFilterAndSearch('group_paid')">
          سداد المجموعة
        </button>

        <button class="btn btn-xs rounded-none h-6 min-h-0 px-4"
          style="background-color: var(--green-500); color: #ffffff;" (click)="exportToExcel()">Excel</button>
        <button class="btn btn-xs rounded-none h-6 min-h-0"
          style="background-color: var(--surface-hover); color: var(--text-color); border-color: var(--surface-border);">طباعة</button>
        <button class="btn btn-xs rounded-none h-6 min-h-0"
          style="background-color: var(--surface-hover); color: var(--text-color); border-color: var(--surface-border);">حذف
          الإفادة</button>
      </div>

    </div>

    <!-- 2. الجدول الرئيسي -->
    <div
      class="flex-grow overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800">
      <div class="overflow-auto h-full">
        <table class="premium-table w-full">
          <thead>
            <tr
              class="bg-indigo-50 dark:bg-indigo-900/20 text-[10px] uppercase font-bold text-indigo-600 dark:text-indigo-400">
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">#</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الاسم</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">تاريخ الإفادة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الإفادة</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right">الموظف</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right text-emerald-600">
                قيمة الإجمالي</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-right w-1/5">ملاحظات</th>
              <th class="py-3 px-4 border-b border-indigo-100 dark:border-indigo-800/50 text-center">إجراءات</th>
            </tr>
          </thead>
          <tbody class="text-[11px]">
            <tr *ngFor="let row of statementRows; let i = index"
              class="border-b border-slate-50 dark:border-slate-800 hover:bg-slate-50/50 transition-colors">
              <td class="py-2 px-3 text-slate-400 font-mono text-[10px]">{{ i + 1 }}</td>
              <td class="py-2 px-3 font-bold text-indigo-700 dark:text-indigo-400">{{ row.name }}</td>
              <td class="py-2 px-3 text-slate-500 font-mono">{{ row.date | date:'dd/MM/yyyy' }}</td>
              <td class="py-2 px-3 text-slate-700 dark:text-slate-300">
                <div class="truncate max-w-[200px]" [title]="row.efada">{{ row.efada }}</div>
              </td>
              <td class="py-2 px-3 text-slate-500 font-medium">{{ row.employee }}</td>
              <td class="py-2 px-3 font-black text-emerald-600 font-mono">{{ row.totalAmount }}</td>
              <td class="py-2 px-3 text-slate-500 italic text-[10px]">{{ row.notes }}</td>
              <td class="py-2 px-3 text-center">
                <button (click)="loadClientProfile(row)"
                  class="premium-btn premium-btn-secondary px-3 py-1 text-[10px] flex items-center gap-1 mx-auto shadow-sm"
                  title="فتح ملف العميل الكامل">
                  <span>📂</span> فتح الملف
                </button>
              </td>
            </tr>
            <tr *ngIf="!statementRows || statementRows.length === 0">
              <td colspan="8" class="text-center py-16 text-slate-400 italic bg-slate-50/20 dark:bg-slate-900/10">
                لا توجد إفادات مسجلة للبحث الحالي
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- 3. Pagination for Search -->
    <div
      class="flex items-center justify-between mt-4 p-3 bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-200 dark:border-slate-700">
      <div class="text-[10px] font-bold text-slate-500">
        إجمالي النتائج: {{ searchStatementsTotal }} إفادة
      </div>
      <div class="flex items-center gap-2">
        <button (click)="prevSearchStatementsPage()" [disabled]="searchStatementsPage === 1"
          class="premium-btn premium-btn-outline px-4 py-1.5 text-xs flex items-center gap-1">
          <span>◀️</span> السابق
        </button>
        <div
          class="px-3 py-1.5 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 text-xs font-bold text-slate-600 dark:text-slate-300 shadow-sm">
          صفحة {{ searchStatementsPage }} من {{ Math.ceil(searchStatementsTotal / searchStatementsPageSize) || 1 }}
        </div>
        <button (click)="nextSearchStatementsPage()"
          [disabled]="searchStatementsPage * searchStatementsPageSize >= searchStatementsTotal"
          class="premium-btn premium-btn-outline px-4 py-1.5 text-xs flex items-center gap-1">
          التالي <span>▶️</span>
        </button>
      </div>
    </div>

  </div>
</div>

<!-- stats -->
<div *ngIf="activeMainTab === 'stats'">
  <h2 class="text-xl font-bold">stats</h2>
</div>

<div *ngIf="loading" class="flex justify-center my-10">
  <span class="loading loading-spinner loading-lg"></span>
</div>

<!-- Detailed Payment Modal -->
<dialog #paymentModal class="modal" dir="rtl">
  <div
    class="premium-modal-box bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-200 border dark:border-slate-800 w-11/12 max-w-4xl relative animate-in fade-in zoom-in duration-300 shadow-2xl dark:shadow-[0_0_50px_rgba(0,0,0,0.5)]">
    <!-- Top Close Button -->
    <button
      class="absolute left-6 top-6 w-10 h-10 rounded-full flex items-center justify-center hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors text-slate-400 dark:text-slate-500"
      (click)="paymentModal.close()">
      <span class="text-xl">✕</span>
    </button>

    <div class="modal-header border-b border-slate-100 dark:border-slate-800 pb-5 mb-5 dark:bg-transparent">
      <div
        class="modal-header-icon shadow-lg shadow-emerald-100 dark:shadow-none dark:bg-slate-800 flex items-center justify-center w-14 h-14 rounded-2xl text-2xl">
        💳</div>
      <div>
        <h3 class="font-black text-2xl tracking-tight text-emerald-600 dark:text-emerald-400">تفاصيل السداد</h3>
        <p class="text-[10px] text-slate-400 dark:text-slate-500 font-bold uppercase tracking-[0.2em]">Payment
          Transaction Record</p>
      </div>
    </div>

    <div *ngIf="selectedPayment" class="space-y-8 p-4">
      <!-- Financial Summary Section -->
      <div
        class="p-6 rounded-3xl bg-emerald-50/50 dark:bg-emerald-900/10 border border-emerald-100/50 dark:border-emerald-800/30 grid grid-cols-1 md:grid-cols-2 gap-6 items-center transition-colors">
        <div class="flex items-center gap-4">
          <div
            class="w-12 h-12 rounded-2xl bg-white dark:bg-slate-800 shadow-sm flex items-center justify-center text-xl">
            💰</div>
          <div>
            <label class="text-xs font-bold text-emerald-600/70 dark:text-emerald-400/70 uppercase">مبلغ السداد</label>
            <div class="text-3xl font-black text-emerald-600 dark:text-emerald-400">{{ selectedPayment.value | number }}
              <span class="text-sm">د.ك</span>
            </div>
          </div>
        </div>
        <div class="flex items-center gap-4 md:border-r border-emerald-100 dark:border-emerald-800/50 md:pr-6">
          <div
            class="w-12 h-12 rounded-2xl bg-white dark:bg-slate-800 shadow-sm flex items-center justify-center text-xl">
            📅</div>
          <div>
            <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase">تاريخ المعاملة</label>
            <div class="text-xl font-bold text-slate-700 dark:text-slate-200">{{ selectedPayment.dateAdded |
              date:'fullDate' }}</div>
          </div>
        </div>
      </div>

      <!-- Secondary Info Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="space-y-1.5">
          <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase">وسيلة الدفع</label>
          <div class="font-bold text-slate-800 dark:text-slate-200 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
            {{ selectedPayment.paymentMethod }}
          </div>
        </div>
        <div class="space-y-1.5">
          <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase">المستخدم المسؤول</label>
          <div class="font-bold text-slate-800 dark:text-slate-200">{{ selectedPayment.userAddedName }}</div>
        </div>
        <div class="space-y-1.5">
          <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase">رقم القيد/السند</label>
          <div class="font-bold text-primary dark:text-blue-400 font-mono">{{ selectedPayment.jouralEntry || '---' }}
          </div>
        </div>
        <div class="space-y-1.5">
          <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase">مندوب المبيعات</label>
          <div class="font-bold text-slate-800 dark:text-slate-200">{{ selectedPayment.salesAgent || 'غير مسجل' }}</div>
        </div>

        <div class="col-span-full mt-4">
          <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase mb-2 block">حالة الملف بعد هذه
            العملية</label>
          <div
            class="p-4 rounded-2xl bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-700 flex items-center justify-between transition-colors">
            <span class="font-bold text-slate-700 dark:text-slate-300">{{ selectedPayment.fileStatusAfter || 'لا توجد
              تغييرات' }}</span>
            <span
              class="px-3 py-1 rounded-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-[10px] font-mono text-slate-400 dark:text-slate-500">REF:
              {{selectedPayment.id}}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-4 border-t border-slate-100 dark:border-slate-800 flex justify-end px-4">
      <form method="dialog">
        <button
          class="bg-emerald-500 hover:bg-emerald-600 text-white w-full md:w-auto px-12 h-12 rounded-xl text-sm font-bold shadow-lg shadow-emerald-500/20 active:scale-95 transition-all">فهمت،
          إغلاق</button>
      </form>
    </div>
  </div>
</dialog>

<!-- Detailed Debt Modal -->
<dialog #debtModal class="modal" dir="rtl">
  <div
    class="premium-modal-box bg-white dark:bg-slate-900 border dark:border-slate-800 text-slate-800 dark:text-slate-200 w-11/12 max-w-5xl relative animate-in fade-in zoom-in duration-300 shadow-2xl dark:shadow-[0_0_50px_rgba(0,0,0,0.5)]">
    <!-- Top Close Button -->
    <button
      class="absolute left-6 top-6 w-10 h-10 rounded-full flex items-center justify-center hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors text-slate-400 dark:text-slate-500"
      (click)="debtModal.close(); selectedDebt = null;">
      <span class="text-xl">✕</span>
    </button>

    <div class="modal-header border-b border-slate-100 dark:border-slate-800 pb-5 mb-5 dark:bg-transparent">
      <div
        class="modal-header-icon shadow-lg shadow-blue-100 dark:shadow-none dark:bg-slate-800 flex flex-center w-14 h-14 rounded-2xl text-2xl items-center justify-center">
        📂</div>
      <div>
        <h3 class="font-black text-2xl tracking-tight text-blue-600 dark:text-blue-400">تفاصيل المديونية</h3>
        <p class="text-[10px] text-slate-400 dark:text-slate-500 font-bold uppercase tracking-[0.2em]">Comprehensive
          Debt & Legal Status</p>
      </div>
    </div>

    <div *ngIf="selectedDebt" class="space-y-8 p-4">
      <!-- File ID Badge -->
      <div class="flex items-center gap-4">
        <div class="px-6 py-2 rounded-2xl bg-slate-900 text-white dark:bg-slate-800 font-black text-lg shadow-lg">ملف
          رقم:
          {{selectedDebt.code}}</div>
        <div
          class="px-6 py-2 rounded-2xl bg-blue-50 text-blue-700 border border-blue-100 dark:bg-blue-900/20 dark:border-blue-800/50 dark:text-blue-300 font-bold delay-100 transition-colors">
          الموكل:
          {{selectedDebt.client}}</div>
      </div>

      <!-- Financial Dashboard Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div
          class="p-6 rounded-3xl bg-amber-50/50 dark:bg-amber-900/10 border border-amber-100/50 dark:border-amber-800/30 transition-colors">
          <label class="text-xs font-bold text-amber-600/70 dark:text-amber-400/70 uppercase">قيمة المطالبة</label>
          <div class="text-3xl font-black text-amber-600 dark:text-amber-500 mt-1">{{ selectedDebt.claim | number }}
            <span class="text-sm">د.ك</span>
          </div>
          <div class="h-1 w-full bg-amber-100 dark:bg-amber-950 rounded-full mt-4 overflow-hidden">
            <div class="h-full bg-amber-500 w-full opacity-30"></div>
          </div>
        </div>
        <div
          class="p-6 rounded-3xl bg-emerald-50/50 dark:bg-emerald-900/10 border border-emerald-100/50 dark:border-emerald-800/30 transition-colors">
          <label class="text-xs font-bold text-emerald-600/70 dark:text-emerald-400/70 uppercase">إجمالي المسدد</label>
          <div class="text-3xl font-black text-emerald-600 dark:text-emerald-400 mt-1">{{ selectedDebt.paid | number }}
            <span class="text-sm">د.ك</span>
          </div>
          <div class="h-1 w-full bg-emerald-100 dark:bg-emerald-950 rounded-full mt-4 overflow-hidden">
            <div class="h-full bg-emerald-500" [style.width]="(selectedDebt.paid / selectedDebt.claim * 100) + '%'">
            </div>
          </div>
        </div>
        <div
          class="p-6 rounded-3xl bg-blue-500 dark:bg-blue-600 shadow-xl shadow-blue-200 dark:shadow-none text-white transition-colors">
          <label class="text-xs font-bold text-blue-100 dark:text-blue-200 uppercase">المبلغ المتبقي</label>
          <div class="text-3xl font-black mt-1">{{ selectedDebt.remaining | number }} <span class="text-sm">د.ك</span>
          </div>
          <p class="text-[10px] mt-4 font-bold opacity-80">صافي المديونية الحالية المستحقة</p>
        </div>
      </div>

      <!-- Case Details Section -->
      <div
        class="bg-slate-50/50 dark:bg-slate-800/30 rounded-3xl p-8 border border-slate-100 dark:border-slate-700/50 transition-colors">
        <h4
          class="text-xs font-black uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-6 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-slate-300 dark:bg-slate-600"></span> Legal Case Profile
        </h4>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="space-y-1.5">
            <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase">المحامى المتابع</label>
            <div class="font-bold text-slate-700 dark:text-slate-300">{{ selectedDebt.lawyerName || 'غير محدد' }}</div>
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase">المحكمة / الجهة</label>
            <div class="font-bold text-slate-700 dark:text-slate-300">{{ selectedDebt.courtName || 'غير محدد' }}</div>
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase">سبب المديونية</label>
            <div class="font-bold text-slate-700 dark:text-slate-300">{{ selectedDebt.debtReason || 'غير محدد' }}</div>
          </div>
          <div class="col-span-full border-t border-slate-100 dark:border-slate-700/50 pt-6 mt-2 space-y-1.5">
            <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase">اسم المدعي القانوني
              الكامل</label>
            <div class="font-black text-slate-900 dark:text-white text-xl">{{ selectedDebt.name }}</div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-4 border-t border-slate-100 dark:border-slate-800 flex justify-end px-4 mb-2">
      <form method="dialog">
        <button
          class="bg-blue-600 hover:bg-blue-700 text-white w-full md:w-auto px-12 h-12 rounded-xl text-sm font-bold shadow-lg shadow-blue-500/20 active:scale-95 transition-all"
          (click)="selectedDebt = null">تمت المراجعة، إغلاق</button>
      </form>
    </div>
  </div>
</dialog>

<!-- Promise to Pay Mini Modal -->
<dialog id="promiseModal" class="modal" dir="rtl">
  <div
    class="modal-box p-0 w-[300px] max-w-[90vw] rounded-2xl shadow-2xl dark:shadow-[0_0_40px_rgba(0,0,0,0.5)] border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 overflow-hidden text-slate-800 dark:text-slate-200">

    <!-- Header -->
    <div
      class="bg-slate-50 dark:bg-slate-800 px-4 py-3 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center">
      <h3 class="font-bold text-sm tracking-wide flex items-center gap-2 text-slate-800 dark:text-slate-100">
        <i class="fas fa-handshake text-emerald-500"></i> خيارات الوعد بالسداد
      </h3>
      <button
        class="w-6 h-6 rounded-full hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-400 flex items-center justify-center transition-colors"
        onclick="document.getElementById('promiseModal').close()">
        <i class="fas fa-times text-xs"></i>
      </button>
    </div>

    <!-- Body -->
    <div class="p-5 space-y-4">
      <!-- Radio Options -->
      <div class="flex flex-col gap-3">
        <label class="flex items-center gap-3 cursor-pointer group">
          <input type="radio" name="promiseType" value="full" [(ngModel)]="promiseToPayType"
            class="radio radio-sm radio-success border-slate-300 dark:border-slate-600">
          <span
            class="text-sm font-bold text-slate-700 dark:text-slate-300 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">سداد
            كلي</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer group">
          <input type="radio" name="promiseType" value="partial" [(ngModel)]="promiseToPayType"
            class="radio radio-sm radio-primary border-slate-300 dark:border-slate-600">
          <span
            class="text-sm font-bold text-slate-700 dark:text-slate-300 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">سداد
            جزئي</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer group">
          <input type="radio" name="promiseType" value="none" [(ngModel)]="promiseToPayType"
            class="radio radio-sm radio-neutral border-slate-300 dark:border-slate-600">
          <span class="text-sm font-bold text-slate-700 dark:text-slate-300 transition-colors">بدون مبلغ</span>
        </label>
      </div>

      <!-- Amount Input -->
      <div class="mt-2 transition-all duration-300" [class.opacity-50]="promiseToPayType === 'none'"
        [class.pointer-events-none]="promiseToPayType === 'none'">
        <div class="relative">
          <input type="number"
            class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg h-10 px-3 text-center text-lg font-black text-emerald-600 dark:text-emerald-400 shadow-inner focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all"
            dir="ltr" [(ngModel)]="promiseToPayAmount" placeholder="0.000" [disabled]="promiseToPayType === 'none'" />
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs font-bold text-slate-400">د.ك</span>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="bg-gray-50 dark:bg-slate-800/50 px-4 py-3 border-t border-slate-100 dark:border-slate-700 flex gap-2">
      <button
        class="bg-blue-600 hover:bg-blue-700 text-white flex-1 h-9 rounded-lg text-sm font-bold shadow-md active:scale-95 transition-all"
        (click)="submitPromiseToPay()">موافق</button>
      <button
        class="bg-white dark:bg-slate-800 hover:bg-rose-50 dark:hover:bg-rose-500/10 text-rose-500 dark:text-rose-400 border border-slate-200 dark:border-slate-700 flex-1 h-9 rounded-lg text-sm font-bold active:scale-95 transition-all"
        onclick="document.getElementById('promiseModal').close()">إلغاء</button>
    </div>

  </div>
</dialog>



<!-- Installment Mini Modal -->
<dialog id="installmentModal" class="modal" dir="rtl">
  <div
    class="modal-box p-0 w-[400px] max-w-[90vw] rounded-2xl shadow-2xl dark:shadow-[0_0_40px_rgba(0,0,0,0.5)] border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 overflow-hidden text-slate-800 dark:text-slate-200">

    <!-- Header -->
    <div
      class="bg-slate-50 dark:bg-slate-800 px-4 py-3 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center">
      <h3 class="font-bold text-sm tracking-wide flex items-center gap-2 text-slate-800 dark:text-slate-100">
        <i
          class="fas fa-calendar-alt text-blue-500 border border-blue-500/20 p-1.5 rounded bg-blue-50 dark:bg-blue-900/30"></i>
        خيارات تقسيط المبلغ
      </h3>
      <button
        class="w-6 h-6 rounded-full hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-400 flex items-center justify-center transition-colors"
        onclick="document.getElementById('installmentModal').close()">
        <i class="fas fa-times text-xs"></i>
      </button>
    </div>

    <!-- Body -->
    <div class="p-5 space-y-4">

      <!-- Amount Input -->
      <div class="flex items-center justify-between gap-4">
        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 w-24">المبلغ</label>
        <div class="relative flex-1">
          <input type="number"
            class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg h-9 px-3 pr-4 text-left text-sm font-black text-emerald-600 dark:text-emerald-400 shadow-inner focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all"
            dir="ltr" [(ngModel)]="installmentAmount" placeholder="0.000" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-bold text-slate-400">د.ك</span>
        </div>
      </div>

      <!-- Date Input -->
      <div class="flex items-center justify-between gap-4">
        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 w-24">تاريخ القسط</label>
        <input type="date"
          class="w-full flex-1 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg h-9 px-3 text-sm font-bold text-slate-700 dark:text-slate-200 shadow-inner focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all"
          [(ngModel)]="installmentDate" />
      </div>

    </div>

    <!-- Action Buttons -->
    <div
      class="bg-gray-50 dark:bg-slate-800/50 px-4 py-3 border-t border-slate-100 dark:border-slate-700 flex gap-2 justify-center">
      <button
        class="bg-white dark:bg-slate-800 hover:bg-rose-50 dark:hover:bg-rose-500/10 text-rose-500 dark:text-rose-400 border border-slate-200 dark:border-slate-700 w-28 h-9 rounded-lg text-sm font-bold active:scale-95 transition-all shadow-sm"
        onclick="document.getElementById('installmentModal').close()">إلغاء</button>
      <button
        class="bg-blue-600 hover:bg-blue-700 text-white w-28 h-9 rounded-lg text-sm font-bold shadow-md active:scale-95 transition-all"
        (click)="submitInstallment()">موافق</button>
    </div>

  </div>
</dialog>

<!-- Review Mini Modal -->
<dialog id="reviewModal" class="modal" dir="rtl">
  <div
    class="modal-box p-0 w-[500px] max-w-[95vw] rounded-2xl shadow-2xl dark:shadow-[0_0_40px_rgba(0,0,0,0.5)] border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 overflow-hidden text-slate-800 dark:text-slate-200">

    <!-- Header -->
    <div
      class="bg-slate-50 dark:bg-slate-800 px-5 py-4 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center">
      <h3 class="font-bold text-base tracking-wide flex items-center gap-3 text-slate-800 dark:text-slate-100">
        <i
          class="fas fa-search-dollar text-purple-500 border border-purple-500/20 p-2 rounded-lg bg-purple-50 dark:bg-purple-900/30"></i>
        خيارات المراجعة
      </h3>
      <button
        class="w-8 h-8 rounded-full hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-400 flex items-center justify-center transition-colors"
        onclick="document.getElementById('reviewModal').close()">
        <i class="fas fa-times"></i>
      </button>
    </div>

    <!-- Body -->
    <div class="p-5 space-y-5">

      <!-- Review Options Grid -->
      <div class="space-y-3">

        <!-- Company Review -->
        <label
          class="flex items-start gap-4 p-3 rounded-xl border border-slate-200 dark:border-slate-700 hover:border-purple-300 dark:hover:border-purple-600 hover:bg-purple-50/50 dark:hover:bg-purple-900/10 cursor-pointer transition-all group"
          [class.bg-purple-50]="reviewType === 'company'" [class.border-purple-400]="reviewType === 'company'"
          [class.dark:bg-purple-900]="reviewType === 'company'" [class.dark:bg-opacity-20]="reviewType === 'company'"
          [class.dark:border-purple-500]="reviewType === 'company'">
          <input type="radio" name="reviewType" value="company" [(ngModel)]="reviewType"
            class="radio radio-sm radio-primary mt-1 border-slate-300 dark:border-slate-600">
          <div>
            <div
              class="text-sm font-bold text-slate-800 dark:text-slate-200 group-hover:text-purple-700 dark:group-hover:text-purple-400 transition-colors">
              مراجعة الشركة</div>
            <div class="text-xs font-medium text-slate-500 dark:text-slate-400 mt-1 leading-relaxed">فى حالة اختيار
              مراجعة الشركة سيتم ترحيلها الى الإفادات.</div>
          </div>
        </label>

        <!-- Admin Review -->
        <label
          class="flex items-start gap-4 p-3 rounded-xl border border-slate-200 dark:border-slate-700 hover:border-purple-300 dark:hover:border-purple-600 hover:bg-purple-50/50 dark:hover:bg-purple-900/10 cursor-pointer transition-all group"
          [class.bg-purple-50]="reviewType === 'admin'" [class.border-purple-400]="reviewType === 'admin'"
          [class.dark:bg-purple-900]="reviewType === 'admin'" [class.dark:bg-opacity-20]="reviewType === 'admin'"
          [class.dark:border-purple-500]="reviewType === 'admin'">
          <input type="radio" name="reviewType" value="admin" [(ngModel)]="reviewType"
            class="radio radio-sm radio-primary mt-1 border-slate-300 dark:border-slate-600">
          <div>
            <div
              class="text-sm font-bold text-slate-800 dark:text-slate-200 group-hover:text-purple-700 dark:group-hover:text-purple-400 transition-colors">
              مراجعة المسئول</div>
            <div class="text-xs font-medium text-slate-500 dark:text-slate-400 mt-1 leading-relaxed">فى حالة اختيار
              مراجعة المسئول سيتم ترحيلها الى المسئول كإجراء.</div>
          </div>
        </label>

        <!-- Management Review -->
        <label
          class="flex items-start gap-4 p-3 rounded-xl border border-slate-200 dark:border-slate-700 hover:border-purple-300 dark:hover:border-purple-600 hover:bg-purple-50/50 dark:hover:bg-purple-900/10 cursor-pointer transition-all group"
          [class.bg-purple-50]="reviewType === 'management'" [class.border-purple-400]="reviewType === 'management'"
          [class.dark:bg-purple-900]="reviewType === 'management'"
          [class.dark:bg-opacity-20]="reviewType === 'management'"
          [class.dark:border-purple-500]="reviewType === 'management'">
          <input type="radio" name="reviewType" value="management" [(ngModel)]="reviewType"
            class="radio radio-sm radio-primary mt-1 border-slate-300 dark:border-slate-600">
          <div>
            <div
              class="text-sm font-bold text-slate-800 dark:text-slate-200 group-hover:text-purple-700 dark:group-hover:text-purple-400 transition-colors">
              مراجعة الإدارة</div>
            <div class="text-xs font-medium text-slate-500 dark:text-slate-400 mt-1 leading-relaxed">فى حالة اختيار
              مراجعة الإدارة سيتم ترحيلها الى الإدارة فوراً للإجراء الحاسم.</div>
          </div>
        </label>

      </div>

      <!-- Notes Input -->
      <div class="space-y-2 pt-2">
        <label class="text-xs font-bold text-slate-600 dark:text-slate-400">أي ملاحظات إضافية؟ (اختياري)</label>
        <textarea
          class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg p-3 text-sm font-semibold text-slate-700 dark:text-slate-200 shadow-inner focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-all min-h-[80px] resize-none"
          [(ngModel)]="reviewNote" placeholder="اكتب ملاحظاتك هنا ليتم إرفاقها بالمراجعة..."></textarea>
      </div>

    </div>

    <!-- Action Buttons -->
    <div
      class="bg-gray-50 dark:bg-slate-800/50 px-5 py-4 border-t border-slate-100 dark:border-slate-700 flex gap-3 justify-center">
      <button
        class="bg-white dark:bg-slate-800 hover:bg-rose-50 dark:hover:bg-rose-500/10 text-rose-500 dark:text-rose-400 border border-slate-200 dark:border-slate-700 w-32 h-10 rounded-lg text-sm font-bold active:scale-95 transition-all shadow-sm"
        onclick="document.getElementById('reviewModal').close()">إلغاء</button>
      <button
        class="bg-purple-600 hover:bg-purple-700 text-white w-32 h-10 rounded-lg text-sm font-bold shadow-md shadow-purple-500/20 active:scale-95 transition-all"
        (click)="submitReview()">موافق</button>
    </div>

  </div>
</dialog>

<app-lookup-modal #lookupModal (itemSelected)="onLookupSelected($event)"></app-lookup-modal>

<!-- History Detail Modal -->
<div class="glass-modal-overlay" *ngIf="historyModalVisible" (click)="historyModalVisible = false">
  <div class="glass-modal-container max-w-md w-full" (click)="$event.stopPropagation()">
    <div class="flex justify-between items-center mb-4 pb-3 border-b border-slate-200">
      <div class="flex items-center gap-2">
        <div class="w-2 h-5 bg-blue-500 rounded-full"></div>
        <h2 class="text-base font-bold text-slate-700">سجل {{selectedHistoryTitle}}</h2>
      </div>
      <button
        class="w-8 h-8 rounded-full hover:bg-slate-100 flex items-center justify-center text-slate-400 transition-colors"
        (click)="historyModalVisible = false">✕</button>
    </div>

    <div class="max-h-[50vh] overflow-y-auto pr-1 custom-scrollbar">
      <table class="w-full text-right border-collapse">
        <thead>
          <tr class="text-[11px] text-slate-400 uppercase font-black border-b border-slate-100">
            <th class="py-2">التاريخ</th>
            <th class="py-2">الموظف</th>
            <th class="py-2">الحالة</th>
          </tr>
        </thead>
        <tbody class="text-[12px]">
          <tr *ngFor="let h of selectedHistoryItems"
            class="border-b border-slate-50 last:border-0 hover:bg-slate-50 transition-colors">
            <td class="py-3 font-bold text-slate-600">{{h.dateAdded | date:'dd/MM/yyyy HH:mm'}}</td>
            <td class="py-3 font-bold text-slate-500">{{h.userName}}</td>
            <td class="py-3">
              <span class="px-3 py-1 rounded-full bg-blue-50 text-blue-600 font-black">{{h.statusName}}</span>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="mt-5 flex justify-end">
      <button
        class="px-6 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-xl font-bold text-xs transition-all"
        (click)="historyModalVisible = false">
        إغلاق
      </button>
    </div>
  </div>
</div>
