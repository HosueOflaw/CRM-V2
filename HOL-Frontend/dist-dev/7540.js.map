            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-3">
                <div
                  class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary shadow-inner">
                  🏷️
                </div>
                <div>
                  <h2 class="text-lg font-black text-slate-800 tracking-tight font-sans">لوحة تحكم التصنيفات</h2>
                  <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">إدارة حالات الملف القانوني
                  </p>
                </div>
              </div>

              <div class="flex items-center gap-2">
                <button (click)="saveAllClassifications()" [disabled]="loading"
                  class="premium-btn premium-btn-primary flex items-center gap-2 px-6 py-2 group text-xs">
                  <span *ngIf="loading"
                    class="w-3 h-3 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                  <span *ngIf="!loading">💾</span>
                  <span>مزامنة التصنيف الكلي</span>
                </button>
              </div>
            </div>

            <!-- Dashboard Grid -->
            <div class="classification-grid">

              <!-- (1) Client Status -->
              <div class="premium-card status-card">
                <div class="status-card-header mb-2">
                  <div class="flex items-center gap-2">
                    <div class="status-icon-box bg-blue-50 text-blue-500">👤</div>
                    <div>
                      <div class="status-label-main text-[11px]">حالة العميل</div>
                      <div class="status-sub-label">Client Status</div>
                    </div>
                  </div>
                </div>
                <div class="flex gap-2">
                  <select class="premium-input text-[11px] font-bold h-9 flex-grow"
                    [(ngModel)]="selectedPerson.classification.clientStatusId">
                    <option [ngValue]="null">اختر الحالة...</option>
                    <option *ngFor="let item of lookupLists.client" [ngValue]="item.id">{{item.name}}</option>
                  </select>
                  <button class="mini-save-btn"
                    (click)="onLookupSelected({id: selectedPerson.classification.clientStatusId, name: ''}, 'client')">
                    <span>💾</span>
                  </button>
                </div>
                <div class="status-history-area">
                  <div class="micro-history-container custom-scrollbar overflow-y-auto mt-2">
                    <table class="micro-history-table">
                      <thead>
                        <tr>
                          <th>التاريخ</th>
                          <th>الموظف</th>
                          <th>الحالة</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr *ngFor="let h of categoryHistories['client']">
                          <td>{{h.dateAdded | date:'dd/MM'}}</td>
                          <td class="truncate max-w-[50px]" [title]="h.userName">{{h.userName}}</td>
                          <td><span class="status-badge-mini bg-blue-50 text-blue-600">{{h.statusName}}</span></td>
                        </tr>
                        <tr *ngIf="!categoryHistories['client']?.length">
                          <td colspan="3" class="text-center py-2 text-slate-400 italic text-[10px]">لا يوجد سجل</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                  <div class="flex justify-center mt-2" *ngIf="(categoryHistories['client']?.length || 0) > 2">
                    <button
                      class="text-[10px] font-bold text-blue-500 hover:text-blue-700 bg-blue-50/50 px-3 py-1 rounded-lg transition-all active:scale-95"
                      (click)="openFullHistory('حالة العميل', categoryHistories['client'])">
                      المزيد ({{categoryHistories['client']?.length || 0}})
                    </button>
                  </div>
                </div>
              </div>

              <!-- (2) Claim Status -->
              <div class="premium-card status-card">
                <div class="status-card-header mb-2">
                  <div class="flex items-center gap-2">
                    <div class="status-icon-box bg-emerald-50 text-emerald-500">⚖️</div>
                    <div>
                      <div class="status-label-main text-[11px]">حالة المطالبة</div>
                      <div class="status-sub-label">Claim Status</div>
                    </div>
                  </div>
                </div>
                <div class="flex gap-2">
                  <select class="premium-input text-[11px] font-bold h-9 flex-grow"
