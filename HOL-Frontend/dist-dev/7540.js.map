<div class="flex flex-col gap-4 h-full">

  <!-- Search Box -->
  <div class="premium-card">
    <div class="join w-full">
      <input #searchInput class="input input-bordered join-item w-full" placeholder="ابحث بالرقم المدني أو الاسم..."
        (input)="onSearchInput()" (keyup.enter)="searchClient(searchInput.value)" />
      <button class="btn join-item rounded-r-full" (click)="searchClient(searchInput.value)">بحث</button>
    </div>
  </div>

  <!-- Quick Actions -->
  <!-- Quick Actions -->
  <div class="premium-card">
    <h3 class="font-bold text-slate-700 mb-4 text-sm tracking-wide">إجراءات سريعة</h3>
    <div class="grid grid-cols-2 gap-2">
      <div class="col-span-2 flex gap-1">
        <button class="premium-btn premium-btn-secondary text-xs p-2 flex-grow" (click)="generateExecutionOrder()">تكليف
          بالوفاء</button>
        <button class="premium-btn premium-btn-secondary text-xs p-2 aspect-square flex items-center justify-center"
          (click)="togglePreview('mandate')" title="معاينة">
          <i class="fas fa-eye text-xs"></i>
        </button>
      </div>
      <div class="col-span-2 flex gap-1">
        <button class="premium-btn premium-btn-secondary text-xs p-2 flex-grow" (click)="generateFaxToWork()">فاكس جهة
          العمل</button>
        <button class="premium-btn premium-btn-secondary text-xs p-2 aspect-square flex items-center justify-center"
          (click)="togglePreview('fax')" title="معاينة">
          <i class="fas fa-eye text-xs"></i>
        </button>
      </div>
      <button class="premium-btn premium-btn-secondary text-xs p-2">العقد</button>
      <button class="premium-btn premium-btn-secondary text-xs p-2">المدنية</button>
      <button class="premium-btn premium-btn-secondary text-xs p-2">رسائل</button>
      <button class="premium-btn premium-btn-secondary text-xs p-2">تحديث الملفات</button>
      <button class="premium-btn premium-btn-secondary text-xs p-2" (click)="openRepresentativeModal()">استمارة
        مندوب</button>
      <button class="premium-btn premium-btn-secondary text-xs p-2">تارجيت الباتشات</button>
      <button class="premium-btn premium-btn-primary col-span-2 text-sm p-3 mt-2 shadow-sm font-black">صحيفة
        الدعوى</button>
    </div>
  </div>

  <!-- Stats Counters -->
  <!-- Stats Counters -->
  <div class="premium-card">
    <div class=" flex flex-col space-y-3 pb-2">
      <div class="flex items-center justify-between px-2 pb-3 border-b border-white/20">
        <div class="text-3xl font-black tracking-tight">{{ dashboardStats?.totalClients || 0 }}</div>
        <div class="text-sm font-semibold opacity-90">عدد العملاء</div>
      </div>
      <div class="flex items-center justify-between px-2 pb-3 border-b border-white/20">
        <div class="text-3xl font-black tracking-tight">{{ dashboardStats?.totalStatements || 0 }}</div>
        <div class="text-sm font-semibold opacity-90">عدد الإفادات</div>
      </div>
      <div class="flex items-center justify-between px-2 pb-3 border-b border-white/20">
        <div class="text-3xl font-black tracking-tight">{{ dashboardStats?.todayStatements || 0 }}</div>
        <div class="text-sm font-semibold opacity-90">الإفادات خلال اليوم</div>
      </div>
      <div class="flex items-center justify-between px-2 pt-1">
        <div class="text-3xl font-black tracking-tight">{{ dashboardStats?.monthStatements || 0 }}</div>
        <div class="text-sm font-semibold opacity-90">الإفادات خلال الشهر</div>
      </div>
    </div>
  </div>
  <div class="premium-card shadow-lg"
    style="background: linear-gradient(135deg, #0f172a, #1e293b); color: white; border: none !important;">
    <div class="space-y-3 text-sm font-medium">
      <div class="flex justify-between items-center opacity-90"><span>إجمالي المديونية:</span><span
          class="font-bold text-base text-blue-200">{{ (financialData?.claimValue || 0) | number }}</span></div>
      <div class="flex justify-between items-center opacity-90"><span>إجمالي المسدد:</span><span
          class="font-bold text-base text-emerald-300">{{ (financialData?.fees || 0) | number }}</span></div>
      <div class="flex justify-between items-center opacity-90 font-black text-rose-300"><span>المتبقي
          الكلي:</span><span class="font-bold text-base">{{ (financialData?.lawFees || 0) | number }}</span></div>

      <div style="border-top: 1px solid rgba(255,255,255,0.15); margin: 0.75rem 0;"></div>

      <div class="p-3 rounded-xl" style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1);">
        <div class="flex justify-between font-black text-emerald-400 text-lg mb-1">
          <span>المسدد:</span><span>{{ (financialData?.fees || 0) | number }}</span>
        </div>
        <div class="flex justify-between text-xs opacity-70"><span>الحالة المالية للعميل:</span><span>محدّث الآن</span>
        </div>
      </div>

      <div class="pt-2 space-y-3">
        <div class="flex justify-between items-center opacity-90 border-t border-white/10 pt-3">
          <span>حالة السداد:</span>
          <span class="badge badge-sm" [ngClass]="(financialData?.lawFees > 0) ? 'badge-warning' : 'badge-success'">
            {{ (financialData?.lawFees > 0) ? 'بانتظار سداد' : 'مسدد بالكامل' }}
          </span>
        </div>
        <div class="flex justify-between items-center opacity-90"><span>إجمالي التخفيض:</span><span
            class="font-bold text-base text-yellow-300">0.000</span></div>
        <div class="flex justify-between font-black text-rose-400 text-lg mt-2 pt-2"
          style="border-top: 1px dashed rgba(255,255,255,0.15);"><span>المتبقي:</span><span>0.000</span></div>
      </div>
    </div>
  </div>
  <div class="premium-card">
    <h3 class="font-bold text-slate-700 mb-4 text-sm tracking-wide">المراجعة</h3>
    <div class="flex flex-col gap-3">
      <div class="w-full">
        <label class="form-label">تاريخ المراجعة</label>
        <input type="date" class="premium-input" style="padding-right:1rem; padding-left:1rem;" />
      </div>
      <div class="flex gap-2 mt-2">
        <button class="premium-btn premium-btn-primary flex-1 shadow-sm">حفظ</button>
        <button class="premium-btn premium-btn-secondary flex-1">تراجع</button>
      </div>
    </div>
  </div>

  <!-- Print Button -->
  <!-- Print Button -->
  <div
    class="premium-card mt-auto transition-colors hover:bg-slate-50 cursor-pointer text-center text-slate-600 font-bold p-0 overflow-hidden"
    style="padding:0 !important;">
    <button
      class="w-full h-full flex items-center justify-center gap-2 p-4 outline-none hover:text-blue-600 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
      </svg>
      طباعة التقرير
    </button>
  </div>

  <!-- Reports (Hidden from screen, visible for print, overlay for preview) -->
  @if (isPreviewMode && activeReport === 'mandate') {
  <app-mandate-report [clientData]="clientData" [isPreview]="true" (close)="togglePreview('mandate')">
  </app-mandate-report>
  }

  @if (isPreviewMode && activeReport === 'fax') {
  <app-fax-to-work-report [clientData]="clientData" [isPreview]="true" (close)="togglePreview('fax')">
  </app-fax-to-work-report>
  }

  <!-- Representative Form Modal -->
  <dialog id="representativeModal" class="modal" dir="rtl">
    <div
      class="modal-box p-0 w-full max-w-lg rounded-2xl shadow-2xl dark:shadow-[0_0_40px_rgba(0,0,0,0.5)] border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 overflow-hidden text-slate-800 dark:text-slate-200 transition-colors duration-300">

      <!-- Premium Title Bar -->
      <div
        class="bg-gradient-to-l from-slate-50 to-white dark:from-slate-800 dark:to-slate-900 px-5 py-4 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center transition-colors duration-300">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-blue-50 dark:bg-emerald-500/20 flex items-center justify-center">
            <i class="fas fa-file-signature text-blue-500 dark:text-emerald-400 text-sm"></i>
          </div>
          <div>
            <h3 class="font-bold text-sm tracking-wide text-slate-800 dark:text-white">استمارة مندوب</h3>
            <p class="text-[10px] text-slate-500 dark:text-slate-400 font-medium tracking-wider">REPRESENTATIVE FORM</p>
          </div>
        </div>
        <button
          class="w-8 h-8 rounded-full bg-slate-50 dark:bg-slate-800 hover:bg-rose-50 dark:hover:bg-rose-500/20 text-slate-400 dark:text-slate-500 hover:text-rose-500 dark:hover:text-rose-400 transition-colors flex items-center justify-center border border-transparent dark:border-white/5"
          onclick="this.closest('dialog').close()" title="إغلاق">
          <i class="fas fa-times"></i>
        </button>
      </div>

      <!-- Form Body -->
      <div class="p-5 space-y-4">

        <!-- Row 1: Code & Contract (Grid) -->
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label class="text-xs font-bold text-slate-500 dark:text-slate-400 pr-1">الكود</label>
            <input type="text"
              class="w-full bg-slate-50 dark:bg-slate-950/50 border border-slate-200 dark:border-slate-800 rounded-lg h-9 px-3 text-sm text-center font-bold text-blue-600 dark:text-emerald-400 shadow-sm dark:shadow-inner transition-colors duration-300"
              [(ngModel)]="representativeForm.code" readonly />
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-bold text-slate-500 dark:text-slate-400 pr-1">رقم العقد</label>
            <input type="text"
              class="w-full bg-slate-50 dark:bg-slate-950/50 border border-slate-200 dark:border-slate-800 rounded-lg h-9 px-3 text-sm text-center font-mono text-slate-600 dark:text-blue-300 shadow-sm dark:shadow-inner transition-colors duration-300"
              [(ngModel)]="representativeForm.contract" readonly />
          </div>
        </div>

        <!-- Row 2: Name -->
        <div class="space-y-1.5">
          <label class="text-xs font-bold text-slate-500 dark:text-slate-400 pr-1">الاسم</label>
          <input type="text"
            class="w-full bg-slate-50 dark:bg-slate-950/50 border border-slate-200 dark:border-slate-800 rounded-lg h-9 px-3 text-sm font-semibold text-slate-700 dark:text-slate-200 shadow-sm dark:shadow-inner transition-colors duration-300"
            [(ngModel)]="representativeForm.name" readonly />
        </div>

        <!-- Row 3: Phone & Amount (Grid) -->
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label class="text-xs font-bold text-slate-500 dark:text-slate-400 pr-1">الهاتف</label>
            <input type="text"
              class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700/50 rounded-lg h-9 px-3 text-sm text-slate-800 dark:text-white shadow-sm focus:border-blue-500 dark:focus:border-blue-500/50 focus:ring-1 focus:ring-blue-500 dark:focus:ring-blue-500/50 transition-all outline-none duration-300"
              [(ngModel)]="representativeForm.phone" placeholder="رقم الهاتف" />
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-bold text-slate-500 dark:text-slate-400 pr-1">المبلغ (د.ك)</label>
            <input type="number"
              class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700/50 rounded-lg h-9 px-3 text-sm text-rose-500 dark:text-rose-400 font-bold shadow-sm focus:border-rose-500 dark:focus:border-rose-500/50 focus:ring-1 focus:ring-rose-500 dark:focus:ring-rose-500/50 transition-all outline-none text-left duration-300"
              dir="ltr" [(ngModel)]="representativeForm.amount" />
          </div>
        </div>

        <!-- Row 4: Date -->
        <div class="space-y-1.5">
          <label class="text-xs font-bold text-slate-500 dark:text-slate-400 pr-1">تاريخ إرسال المندوب</label>
          <input type="date"
            class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700/50 rounded-lg h-9 px-3 text-sm text-slate-800 dark:text-white shadow-sm focus:border-blue-500 dark:focus:border-blue-500/50 outline-none duration-300 transition-colors"
            [(ngModel)]="representativeForm.sendDate" />
        </div>

        <!-- Row 5: Notes -->
        <div class="space-y-1.5">
          <label class="text-xs font-bold text-slate-500 dark:text-slate-400 pr-1">ملاحظات</label>
          <textarea
            class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700/50 rounded-lg p-3 text-sm text-slate-800 dark:text-white shadow-sm focus:border-blue-500 dark:focus:border-blue-500/50 resize-none outline-none min-h-[60px] duration-300 transition-colors"
            [(ngModel)]="representativeForm.notes" placeholder="اكتب ملاحظاتك..."></textarea>
        </div>

        <!-- Row 6: Address -->
        <div class="space-y-1.5">
          <label class="text-xs font-bold text-slate-500 dark:text-slate-400 pr-1">العنوان التفصيلي</label>
          <textarea
            class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700/50 rounded-lg p-3 text-sm text-slate-800 dark:text-white shadow-sm focus:border-blue-500 dark:focus:border-blue-500/50 resize-none outline-none min-h-[70px] duration-300 transition-colors"
            [(ngModel)]="representativeForm.address" placeholder="العنوان..."></textarea>
        </div>

      </div>

      <!-- Action Buttons -->
      <div
        class="bg-gray-50 dark:bg-slate-950/50 px-5 py-4 border-t border-slate-100 dark:border-white/5 flex gap-3 transition-colors duration-300">
        <button
          class="bg-blue-600 dark:bg-emerald-500 hover:bg-blue-700 dark:hover:bg-emerald-400 text-white dark:text-slate-950 flex-1 h-10 rounded-lg text-sm font-bold transition-all shadow-md shadow-blue-500/20 dark:shadow-[0_0_15px_rgba(16,185,129,0.2)] active:scale-95"
          (click)="submitRepresentativeForm()">
          <i class="fas fa-paper-plane px-1 dark:hidden"></i>
          <i class="fas fa-paper-plane ml-2 hidden dark:inline"></i> إرسال
        </button>
        <button
          class="bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 text-slate-700 dark:text-white flex-1 h-10 rounded-lg text-sm font-bold transition-all active:scale-95"
          (click)="submitRepresentativeForm()">
          <i class="fas fa-edit px-1 dark:hidden"></i>
          <i class="fas fa-edit ml-2 hidden dark:inline"></i> تعديل
        </button>
        <form method="dialog">
          <button
            class="bg-white dark:bg-rose-500/10 hover:bg-rose-50 dark:hover:bg-rose-500/20 text-rose-500 dark:text-rose-400 border border-slate-200 dark:border-rose-500/20 w-20 h-10 rounded-lg text-sm font-bold transition-all active:scale-95 shadow-sm dark:shadow-none">
            إلغاء
          </button>
        </form>
      </div>

    </div>
  </dialog>
</div>