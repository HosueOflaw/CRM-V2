<div class="grid grid-cols-12 gap-4 p-1 bg-base-200 min-h-screen" dir="rtl">
  <div class="col-span-12 md:col-span-2">
    <app-app-sidebar (search)="onClientSelected($event)" [financialData]="financial"
      [dashboardStats]="dashboardStats"></app-app-sidebar>
  </div>
  <div class="col-span-12 md:col-span-10 relative">
    <div *ngIf="loading"
      class="absolute inset-0 bg-white/50 backdrop-blur-[2px] z-50 flex items-center justify-center rounded-2xl">
      <div class="flex flex-col items-center gap-3">
        <span class="loading loading-spinner loading-lg text-primary"></span>
        <span class="text-sm font-bold text-primary animate-pulse">جاري جلب البيانات...</span>
      </div>
    </div>
    <app-main-content [selectedPerson]="selectedPerson" [financialData]="financial" [clientRows]="clientRows"
      [attachments]="attachments" [payments]="payments" [additionalAmounts]="additionalAmounts" [audits]="audits"
      [autoNumbers]="autoNumbers" [callcenterStatements]="callcenterStatements" [classifications]="classifications"
      [statuses]="statuses" [numbers]="contacts" [notes]="notes" [notesTotal]="notesTotal"
      [statusesTotal]="statusesTotal" [auditsTotal]="auditsTotal" [statementsTotal]="statementsTotal"
      (contactAdded)="fetchContactsOnly()" (statementSaved)="saveStatement($event)"
      (statusChanged)="handleStatusChanged()" (loadClientRequest)="onClientSelected($event)"
      (pageChange)="handlePageChange($event)">
    </app-main-content>
  </div>
</div>